<style>
.card-custom {
  border-radius: 12px;
  border: 2px solid #e5e7eb;
  transition: all 0.25s ease;
  background: #fff;
}

.card-custom:hover {
  transform: translateY(-4px);
  box-shadow: 0 10px 25px rgba(0,0,0,0.08);
}

/* Theme accents */
.border-welcome {
  border-left: 5px solid #dc3545; /* red */
}

.border-purpose {
  border-left: 5px solid #0d6efd; /* blue */
}

.border-direction {
  border-left: 5px solid #198754; /* green */
}

/* Title colors */
.title-welcome {
  color: #dc3545;
}

.title-purpose {
  color: #0d6efd;
}

.title-direction {
  color: #198754;
}

/* Text styling */
.card-text {
  color: #555;
  line-height: 1.6;
}

/* Green highlight */
.highlight-green {
  color: #198754;
  font-weight: 600;
}
</style>


<div class="container mt-5">
  <div class="row g-4">

    <!-- Card 1 -->
    <div class="col-md-4">
      <div class="card card-custom border-welcome h-100 p-4">
        <h4 class="mb-3 title-welcome">Welcome</h4>
        <p class="card-text">
          Welcome, <span class="highlight-green"><%= user.name %></span>.<br><br>
          You are now inside 
          <span class="highlight-green">Chessy Family Projects</span>.
        </p>
      </div>
    </div>

    <!-- Card 2 -->
    <div class="col-md-4">
      <div class="card card-custom border-purpose h-100 p-4">
        <h4 class="mb-3 title-purpose">Purpose</h4>
        <p class="card-text">
          This system is structured to support organized work, accurate tracking,
          and consistent performance across all activities.
        </p>
      </div>
    </div>

    <!-- Card 3 -->
    <div class="col-md-4">
      <div class="card card-custom border-direction h-100 p-4">
        <h4 class="mb-3 title-direction">Direction</h4>
        <p class="card-text">
          Review your environment, understand your workflow,
          and proceed with your tasks.
        </p>
      </div>
    </div>

  </div>
</div>
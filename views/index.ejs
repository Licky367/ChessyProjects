<div class="container mt-5">

  <div class="row g-4">

    <!-- Card 1: Welcome -->
    <div class="col-md-4">
      <div class="card shadow-sm h-100 p-4">
        <h4 class="mb-3">Welcome</h4>
        <p class="mb-0">
          Welcome, <strong><%= user.name %></strong>.<br><br>
          You are now inside Chessy Family Projects.
        </p>
      </div>
    </div>

    <!-- Card 2: Purpose -->
    <div class="col-md-4">
      <div class="card shadow-sm h-100 p-4">
        <h4 class="mb-3">Purpose</h4>
        <p class="mb-0">
          This system is structured to support organized work, accurate tracking,
          and consistent performance across all activities.
        </p>
      </div>
    </div>

    <!-- Card 3: Direction -->
    <div class="col-md-4">
      <div class="card shadow-sm h-100 p-4">
        <h4 class="mb-3">Direction</h4>
        <p class="mb-0">
          Review your environment, understand your workflow,
          and proceed with your tasks.
        </p>
      </div>
    </div>

  </div>

</div>
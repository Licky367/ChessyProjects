<div class="page">

  <!-- =========================
       SALES FORM (MASTER FORM)
  ========================= -->
  <form method="POST" action="/sales">

    <!-- =========================
         PRICE SECTION (TOP)
    ========================= -->
    <div class="card">
      <h2>Milk Price (KES per Liter)</h2>

      <div class="row">
        <div class="col">
          <label>Current Price</label>

          <input 
            type="number" 
            step="0.1" 
            name="price"
            value="<%= currentPrice || '' %>"
            <%= user?.role !== 'admin' ? 'readonly' : 'required' %>
          >
        </div>
      </div>

      <% if (user?.role !== 'admin') { %>
        <small style="color:#888;">Only admins can update price</small>
      <% } %>
    </div>


    <!-- =========================
         STANDING ORDERS
    ========================= -->
    <div class="card">
      <h2>Standing Orders (Daily Supply Contracts)</h2>

      <!-- ADD FORM -->
      <form method="POST" action="/sales/standing">
        <div class="row">
          <div class="col">
            <label>Customer Name</label>
            <input type="text" name="customerName" required>
          </div>

          <div class="col">
            <label>Liters Per Day</label>
            <input type="number" step="0.1" min="0" name="liters" required>
          </div>
        </div>

        <button>Add Standing Order</button>
      </form>

      <!-- TABLE -->
      <% if (standingOrders && standingOrders.length > 0) { %>
        <table>
          <thead>
            <tr>
              <th>Customer</th>
              <th>Liters</th>
              <th>Status</th>
              <% if (user?.role === 'admin') { %>
                <th>Action</th>
              <% } %>
            </tr>
          </thead>

          <tbody>
            <% let index = 0; %>

            <% standingOrders.forEach(o => { %>
              <tr class="<%= o.isFuture ? 'future' : '' %>">

                <td>
                  <%= o.customerName %>

                  <!-- 🔥 Include ONLY active in submission -->
                  <% if (!o.isFuture) { %>
                    <input type="hidden" name="records[<%= index %>][customerName]" value="<%= o.customerName %>">
                  <% } %>
                </td>

                <td>
                  <%= o.liters %>

                  <% if (!o.isFuture) { %>
                    <input type="hidden" name="records[<%= index %>][liters]" value="<%= o.liters %>">
                  <% } %>
                </td>

                <td>
                  <%= o.isFuture ? 'Effective Tomorrow' : 'Active' %>
                </td>

                <% if (user?.role === 'admin') { %>
                  <td>
                    <form method="POST" action="/sales/standing/omit">
                      <input type="hidden" name="id" value="<%= o._id %>">
                      <button class="omit-btn">Omit</button>
                    </form>
                  </td>
                <% } %>

              </tr>

              <% if (!o.isFuture) index++; %>
            <% }) %>

          </tbody>
        </table>
      <% } else { %>
        <div class="empty">No standing orders yet.</div>
      <% } %>

    </div>


    <!-- =========================
         MANUAL ORDERS INPUT
    ========================= -->
    <div class="card">
      <h2>Manual Orders</h2>

      <table>
        <thead>
          <tr>
            <th>Customer</th>
            <th>Liters</th>
          </tr>
        </thead>

        <tbody>

          <% for(let i = 0; i < 5; i++) { %>
            <tr>
              <td>
                <input 
                  type="text" 
                  name="records[<%= index + i %>][customerName]" 
                  placeholder="Customer name"
                >
              </td>

              <td>
                <input 
                  type="number" 
                  step="0.1" 
                  min="0"
                  name="records[<%= index + i %>][liters]" 
                  placeholder="Liters"
                >
              </td>
            </tr>
          <% } %>

        </tbody>
      </table>

    </div>


    <!-- =========================
         SUBMIT BUTTON
    ========================= -->
    <div class="card">
      <button style="width:100%;">Submit Daily Sales</button>
    </div>

  </form>


  <!-- =========================
       TOTAL DISPLAY
  ========================= -->
  <% if (totalSales !== undefined) { %>
    <div class="card total-box">
      Total Sold Today: <%= totalSales %> Liters
    </div>
  <% } %>

</div>
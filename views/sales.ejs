<div class="page">

  <!-- =========================
       SALES FORM (MASTER)
  ========================= -->
  <form method="POST" action="/sales">

    <!-- =========================
         PRICE SECTION (TOP)
    ========================= -->
    <div class="card">
      <h2>Milk Price (KES per Liter)</h2>

      <div class="row">
        <div class="col">
          <label>Current Price</label>

          <input 
            type="number" 
            step="0.1" 
            name="price"
            value="<%= currentPrice || '' %>"
            <%= user?.role !== 'admin' ? 'readonly' : '' %>
          >
        </div>
      </div>

      <% if (user?.role !== 'admin') { %>
        <small style="color:#888;">
          Only admins can update price
        </small>
      <% } %>
    </div>


    <!-- =========================
         STANDING ORDERS
    ========================= -->
    <div class="card">
      <h2>Standing Orders</h2>

      <!-- ADD ORDER (SEPARATE FORM) -->
      <form method="POST" action="/sales/standing">
        <div class="row">
          <div class="col">
            <label>Customer Name</label>
            <input type="text" name="customerName" required>
          </div>

          <div class="col">
            <label>Liters Per Day</label>
            <input type="number" step="0.1" min="0" name="liters" required>
          </div>
        </div>

        <button type="submit">Add Standing Order</button>
      </form>

      <!-- TABLE -->
      <% if (standingOrders && standingOrders.length > 0) { %>
        <table>
          <thead>
            <tr>
              <th>Customer</th>
              <th>Liters</th>
              <th>Status</th>
              <% if (user?.role === 'admin') { %>
                <th>Action</th>
              <% } %>
            </tr>
          </thead>

          <tbody>
            <% standingOrders.forEach(o => { %>
              <tr class="<%= o.isFuture ? 'future' : '' %>">

                <td><%= o.customerName %></td>
                <td><%= o.liters %></td>

                <td>
                  <%= o.isFuture ? 'Effective Tomorrow' : 'Active' %>
                </td>

                <% if (user?.role === 'admin') { %>
                  <td>
                    <form method="POST" action="/sales/standing/omit">
                      <input type="hidden" name="id" value="<%= o._id %>">
                      <button type="submit" class="omit-btn">Omit</button>
                    </form>
                  </td>
                <% } %>

              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <div class="empty">No standing orders yet.</div>
      <% } %>

    </div>


    <!-- =========================
         MANUAL ORDERS
    ========================= -->
    <div class="card">
      <h2>Manual Orders</h2>

      <table>
        <thead>
          <tr>
            <th>Customer</th>
            <th>Liters</th>
          </tr>
        </thead>

        <tbody>
          <% const baseIndex = standingOrders ? standingOrders.filter(o => !o.isFuture).length : 0; %>

          <% for(let i = 0; i < 5; i++) { %>
            <tr>
              <td>
                <input 
                  type="text"
                  name="records[<%= baseIndex + i %>][customerName]"
                  placeholder="Customer name"
                >
              </td>

              <td>
                <input 
                  type="number"
                  step="0.1"
                  min="0"
                  name="records[<%= baseIndex + i %>][liters]"
                  placeholder="Liters"
                >
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>

    </div>


    <!-- =========================
         SUBMIT
    ========================= -->
    <div class="card">
      <button type="submit" style="width:100%;">
        Submit Daily Sales
      </button>
    </div>

  </form>


  <!-- =========================
       TOTAL
  ========================= -->
  <% if (totalSales !== undefined) { %>
    <div class="card total-box">
      Total Sold Today: <%= totalSales %> Liters
    </div>
  <% } %>

</div>
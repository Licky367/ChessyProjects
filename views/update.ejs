<script src="/socket.io/socket.io.js"></script>

<div class="container mt-4">

<div class="card">

<!-- PROFILE TOP -->
<div class="profile-top">

<!-- LEFT -->
<div class="profile-left">

<img
src="<%= dairy.displayImage %>"
alt="<%= dairy.name %>"
id="profilePreview"
class="avatar-img"
>

</div>

<!-- RIGHT -->
<div class="profile-right">

<div class="name-row">
<h2>

<% if (user?.role === 'admin') { %>
<span class="editable" data-field="name" data-value="<%= dairy.name %>">
<%= dairy.name %>
</span>
<% } else { %>
<%= dairy.name %>
<% } %>

</h2>
</div>

<div class="meta">
<strong>Code:</strong>

<% if (user?.role === 'admin') { %>
<span class="editable" data-field="code" data-value="<%= dairy.code %>">
<%= dairy.code %>
</span>
<% } else { %>
<%= dairy.code %>
<% } %>

</div>

<% if (dairy.hasIdentity) { %>
<div class="meta"><strong>Gender:</strong> <%= dairy.gender %></div>
<div class="meta"><strong>Age:</strong> <%= dairy.ageText %></div>
<% } %>

<div class="meta">
<strong>Mass:</strong>

<% if (user?.role === 'admin') { %>
<span class="editable" data-field="mass" data-value="<%= dairy.mass %>">
<%= dairy.mass %>
</span>
<% } else { %>
<%= dairy.mass %>
<% } %>

Kgs
</div>

<% if (dairy.isFemale) { %>
<div class="meta">

<strong>Status:</strong>

<% if (user?.role === 'admin') { %>

<label>
<input type="checkbox" id="milkingToggle" <%= dairy.isMilking ? 'checked' : '' %>>

<span id="milkBadge" class="badge <%= dairy.isMilking ? 'bg-success' : 'bg-secondary' %>">
<%= dairy.isMilkingText %>
</span>
</label>

<% } else { %>

<span class="badge <%= dairy.isMilking ? 'bg-success' : 'bg-secondary' %>">
<%= dairy.isMilkingText %>
</span>

<% } %>

</div>
<% } %>

</div>
</div>

<!-- DELETE -->
<% if (user?.role === 'admin') { %>
<div class="actions">
<form action="/dairy/<%= dairy._id %>?_method=DELETE" method="POST">
<button class="btn btn-danger">Delete Profile</button>
</form>
</div>
<% } %>

</div>

</div>


<!-- ========================= -->
<!-- 🟥 MEDICAL FEED (NEW ADDITION) -->
<!-- ========================= -->

<% if (dairy.medicalAttention && dairy.medicalAttention.isMarked) { %>

<div id="medicalFeed" class="medical-feed-card">

  <div class="feed-header">
    <div class="feed-avatar">
      <img src="https://ui-avatars.com/api/?name=<%= user?.name || 'System' %>&background=c62828&color=fff">
    </div>

    <div class="feed-meta">
      <strong><%= user?.name || 'System Update' %></strong>
      <div class="feed-time">
        <%= dairy.medicalAttention.markedAt ? new Date(dairy.medicalAttention.markedAt).toLocaleString() : '' %>
      </div>
    </div>
  </div>

  <div class="feed-body">
    <div class="feed-title">🚨 Medical Attention Required</div>

    <div class="feed-content">
      <strong>Type:</strong> <%= dairy.medicalAttention.type %><br>
      <strong>Details:</strong> <%= dairy.medicalAttention.details %>
    </div>
  </div>

</div>

<% } %>


<!-- ========================= -->
<!-- IMAGE ACTION SHEET -->
<!-- ========================= -->
<div class="fb-sheet" id="imageSheet">

<button onclick="openGallery()">👁 View Photo</button>

<% if (user?.role === 'admin') { %>

<button onclick="document.getElementById('imageInput').click()">
📷 Change Photo
</button>

<form action="/dairy/<%= dairy._id %>/image?_method=DELETE" method="POST">
<button type="submit">🗑 Delete Photo</button>
</form>

<% } %>

<button onclick="closeSheet()">Cancel</button>

</div>


<!-- ========================= -->
<!-- GALLERY MODAL -->
<!-- ========================= -->
<div class="modal fade" id="viewImageModal" tabindex="-1">
<div class="modal-dialog modal-dialog-centered modal-xl">
<div class="modal-content border-0">

<div class="gallery-box">

<button class="gallery-nav gallery-prev" onclick="prevImage()">‹</button>

<img id="galleryImage" class="gallery-img" src="">

<button class="gallery-nav gallery-next" onclick="nextImage()">›</button>

<button
class="btn btn-light rounded-circle"
style="position:absolute;bottom:20px;right:20px;width:55px;height:55px;"
data-bs-toggle="modal"
data-bs-target="#commentsModal"
>
💬
</button>

</div>
</div>
</div>
</div>


<!-- ========================= -->
<!-- COMMENTS MODAL -->
<!-- ========================= -->
<div class="modal fade" id="commentsModal" tabindex="-1">
<div class="modal-dialog">
<div class="modal-content">

<div class="modal-header">
<h5 class="modal-title">Comments</h5>
<button class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body">

<div id="commentsContainer">

<% if (updates.length) { %>

<% updates.forEach(item => { %>
<div class="comment-item">
<strong><%= item.userName %></strong><br>
<%= item.comment %><br>
<small><%= item.dateText %></small>
</div>
<% }) %>

<% } else { %>
<p id="noComments">No comments yet.</p>
<% } %>

</div>

<% if (user) { %>
<form id="commentForm" class="comment-box">
<textarea name="comment" id="commentInput" rows="2" required></textarea>
<button class="btn btn-primary">Post</button>
</form>
<% } %>

</div>
</div>
</div>
</div>


<!-- ========================= -->
<!-- IMAGE UPLOAD -->
<!-- ========================= -->
<form
id="uploadForm"
action="/dairy/<%= dairy._id %>/image?_method=PUT"
method="POST"
enctype="multipart/form-data"
style="display:none;"
>
<input type="file" name="profileImage" id="imageInput"
accept="image/*"
onchange="document.getElementById('uploadForm').submit()">
</form>


<!-- ========================= -->
<!-- STYLES (MEDICAL FEED) -->
<!-- ========================= -->
<style>

.medical-feed-card{
  background:#fff;
  border-left:5px solid #c62828;
  border-radius:10px;
  padding:12px;
  margin-top:15px;
  box-shadow:0 4px 10px rgba(0,0,0,.08);
}

.feed-header{
  display:flex;
  align-items:center;
  gap:10px;
}

.feed-avatar img{
  width:40px;
  height:40px;
  border-radius:50%;
}

.feed-meta strong{
  font-size:14px;
}

.feed-time{
  font-size:12px;
  color:#777;
}

.feed-body{
  margin-top:10px;
}

.feed-title{
  font-weight:bold;
  color:#c62828;
  margin-bottom:5px;
}

.feed-content{
  font-size:13px;
  color:#333;
}

</style>


<!-- ========================= -->
<!-- SOCKET + JS -->
<!-- ========================= -->
<script>

const dairyId = "<%= dairy._id %>";
const socket = io();

socket.emit("joinDairy", dairyId);

/* COMMENTS */
socket.on("commentAdded", (data) => {
const container = document.getElementById("commentsContainer");

const div = document.createElement("div");
div.className = "comment-item";

div.innerHTML = `
<strong>${data.userName}</strong><br>
${data.comment}<br>
<small>${data.dateText}</small>
`;

container.prepend(div);
});


/* 🟥 MEDICAL MARKED */
socket.on("medicalMarked", (data) => {

let feed = document.getElementById("medicalFeed");

if (!feed) {
  const div = document.createElement("div");
  div.id = "medicalFeed";
  div.className = "medical-feed-card";

  div.innerHTML = `
    <div class="feed-header">
      <div class="feed-avatar">
        <img src="https://ui-avatars.com/api/?name=${data.userName || 'System'}&background=c62828&color=fff">
      </div>

      <div class="feed-meta">
        <strong>${data.userName || 'System Update'}</strong>
        <div class="feed-time">Just now</div>
      </div>
    </div>

    <div class="feed-body">
      <div class="feed-title">🚨 Medical Attention Required</div>
      <div class="feed-content">
        <strong>Type:</strong> ${data.type}<br>
        <strong>Details:</strong> ${data.details}
      </div>
    </div>
  `;

  document.querySelector(".container").prepend(div);
}

});


/* 🟥 MEDICAL UNMARKED */
socket.on("medicalUnmarked", () => {
const feed = document.getElementById("medicalFeed");
if (feed) feed.remove();
});

</script>
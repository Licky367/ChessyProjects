<script src="/socket.io/socket.io.js"></script>

<div class="container mt-4">

<!-- ========================= -->
<!-- PROFILE CARD -->
<!-- ========================= -->

<div class="card">

<div class="profile-top">

<div class="profile-left">
<img src="<%= dairy.displayImage %>" class="avatar-img">
</div>

<div class="profile-right">

<h2>
<% if (user?.role === 'admin') { %>
<span class="editable" data-field="name"><%= dairy.name %></span>
<% } else { %>
<%= dairy.name %>
<% } %>
</h2>

<div class="meta">
<strong>Code:</strong>
<% if (user?.role === 'admin') { %>
<span class="editable" data-field="code"><%= dairy.code %></span>
<% } else { %>
<%= dairy.code %>
<% } %>
</div>

<% if (dairy.hasIdentity) { %>
<div class="meta"><strong>Gender:</strong> <%= dairy.gender %></div>
<div class="meta"><strong>Age:</strong> <%= dairy.ageText %></div>
<% } %>

<div class="meta">
<strong>Mass:</strong>
<% if (user?.role === 'admin') { %>
<span class="editable" data-field="mass"><%= dairy.mass %></span>
<% } else { %>
<%= dairy.mass %>
<% } %> Kgs
</div>

<% if (dairy.isFemale) { %>
<div class="meta">
<strong>Status:</strong>
<span class="badge <%= dairy.isMilking ? 'bg-success' : 'bg-secondary' %>">
<%= dairy.isMilkingText %>
</span>
</div>

<div class="meta" style="margin-top:8px;">
<a href="/milk/history/<%= dairy._id %>" class="btn btn-primary btn-sm">
🍼 View Milking History
</a>
</div>
<% } %>

</div>
</div>

<% if (user?.role === 'admin') { %>
<div class="actions">
<form action="/dairy/<%= dairy._id %>?_method=DELETE" method="POST">
<button class="btn btn-danger">Delete Profile</button>
</form>
</div>
<% } %>

</div>


<!-- ========================= -->
<!-- CREATE POST -->
<!-- ========================= -->

<% if (user) { %>
<div class="card mt-3 p-3">

<form id="postForm" enctype="multipart/form-data">

<textarea 
id="postText"
placeholder="<%= user.name %>, say something about this project..."
rows="2"
required
></textarea>

<input type="file" id="postImage" accept="image/*">

<button type="submit" class="btn btn-success mt-2">Post</button>

</form>

</div>
<% } %>


<!-- ========================= -->
<!-- FEED -->
<!-- ========================= -->

<div id="postFeed">

<% posts.forEach(post => { %>

<div class="feed-card" data-id="<%= post._id %>">

<!-- HEADER -->
<div class="feed-header">

<div class="feed-user">
<img 
src="<%= post.userImage || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(post.userName) %>" 
class="avatar-sm"
>

<div>
<strong><%= post.userName %></strong><br>
<small><%= post.dateText %></small>
</div>
</div>

<% if (user && (user._id.toString() === post.userId.toString() || user.role === 'admin')) { %>
<button class="delete-post" data-id="<%= post._id %>">🗑</button>
<% } %>

</div>

<!-- BODY -->
<div class="feed-body">

<!-- TEXT -->
<% if (post.text) { %>
<p><%= post.text %></p>
<% } %>

<!-- IMAGE -->
<% if (post.image) { %>
<img src="/uploads/<%= post.image %>" class="feed-img">
<% } %>

<!-- 🟩 WEEKLY MILKING TABLE -->
<% if (post.type === 'weekly') { %>

<div class="weekly-block">

<table class="weekly-table">
<thead>
<tr>
<th>Day</th>
<th>Total (L)</th>
</tr>
</thead>

<tbody>
<% post.weekly.days.forEach(d => { %>
<tr>
<td><%= d.day %></td>
<td><%= d.total %> L</td>
</tr>
<% }) %>
</tbody>
</table>

<div class="weekly-average">
Average: <strong><%= post.weekly.average %> L/day</strong>
</div>

</div>

<% } %>

</div>

<!-- ACTIONS -->
<div class="feed-actions">

<button class="like-btn" data-id="<%= post._id %>">
👍 <span class="like-count"><%= post.likes %></span>
</button>

<button class="toggle-comments">
💬 <span><%= post.comments.length %></span>
</button>

</div>

<!-- COMMENTS -->
<div class="comment-section">

<% post.comments.forEach(c => { %>
<div class="comment-item" data-id="<%= c._id %>">

<div class="comment-user">
<img 
src="<%= c.userImage || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(c.userName) %>" 
class="avatar-xs"
>

<div>
<strong><%= c.userName %></strong><br>
<%= c.text %>
</div>
</div>

<% if (user && (
user._id.toString() === c.userId.toString() ||
user._id.toString() === post.userId.toString() ||
user.role === 'admin'
)) { %>
<button class="delete-comment" data-id="<%= c._id %>">❌</button>
<% } %>

</div>
<% }) %>

<% if (user) { %>
<form class="comment-form" data-id="<%= post._id %>">
<textarea required></textarea>
<button type="submit">Post</button>
</form>
<% } %>

</div>

</div>

<% }) %>

</div>


<!-- ========================= -->
<!-- STYLES -->
<!-- ========================= -->

<style>

.feed-card{
background:#fff;
padding:12px;
margin-top:12px;
border-radius:10px;
box-shadow:0 3px 8px rgba(0,0,0,.08);
}

.feed-header{
display:flex;
justify-content:space-between;
align-items:center;
}

.feed-user{
display:flex;
gap:10px;
align-items:center;
}

.avatar-sm{
width:40px;
height:40px;
border-radius:50%;
}

.avatar-xs{
width:28px;
height:28px;
border-radius:50%;
}

.feed-img{
width:100%;
border-radius:8px;
margin-top:8px;
}

.feed-actions{
display:flex;
gap:10px;
margin-top:8px;
}

.comment-section{
display:none;
margin-top:10px;
}

.comment-section.active{
display:block;
}

.comment-user{
display:flex;
gap:8px;
}

.delete-post,
.delete-comment{
color:red;
border:none;
background:none;
cursor:pointer;
}

.weekly-table{
width:100%;
border-collapse:collapse;
margin-top:10px;
}

.weekly-table th,
.weekly-table td{
border:1px solid #ddd;
padding:6px;
font-size:13px;
}

.weekly-average{
margin-top:8px;
font-weight:bold;
color:#2e7d32;
}

</style>


<!-- ========================= -->
<!-- SOCKET + JS -->
<!-- ========================= -->

<script>

const dairyId = "<%= dairy._id %>";
const socket = io();

socket.emit("joinDairy", dairyId);

<% if (user) { %>
socket.emit("setUser", {
_id: "<%= user._id %>",
name: "<%= user.name %>",
role: "<%= user.role %>"
});
<% } %>


/* CREATE POST */
document.getElementById("postForm")?.addEventListener("submit", async e => {
e.preventDefault();

const formData = new FormData();
formData.append("text", postText.value);
if(postImage.files[0]) formData.append("image", postImage.files[0]);

await fetch(`/dairy/${dairyId}/post`,{
method:"POST",
body:formData
});

postText.value = "";
postImage.value = "";
});


/* LIKE */
document.addEventListener("click", async e=>{
if(e.target.closest(".like-btn")){
const id = e.target.closest(".like-btn").dataset.id;
await fetch(`/post/${id}/like`,{method:"POST"});
}
});


/* TOGGLE COMMENTS */
document.addEventListener("click", e=>{
if(e.target.closest(".toggle-comments")){
const card = e.target.closest(".feed-card");
card.querySelector(".comment-section").classList.toggle("active");
}
});


/* COMMENT */
document.addEventListener("submit", async e=>{
if(e.target.classList.contains("comment-form")){
e.preventDefault();

const id = e.target.dataset.id;
const text = e.target.querySelector("textarea").value;

await fetch(`/post/${id}/comment`,{
method:"POST",
headers:{ "Content-Type":"application/json" },
body: JSON.stringify({ text })
});

e.target.querySelector("textarea").value="";
}
});


/* DELETE POST */
document.addEventListener("click", async e=>{
if(e.target.classList.contains("delete-post")){
await fetch(`/post/${e.target.dataset.id}`,{method:"DELETE"});
}
});


/* DELETE COMMENT */
document.addEventListener("click", async e=>{
if(e.target.classList.contains("delete-comment")){
await fetch(`/comment/${e.target.dataset.id}`,{method:"DELETE"});
}
});

</script>
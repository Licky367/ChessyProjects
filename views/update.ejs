<script src="/socket.io/socket.io.js"></script>

<div class="container mt-4">

<!-- ========================= -->
<!-- PROFILE CARD -->
<!-- ========================= -->

<div class="card">

<div class="profile-top">

<div class="profile-left">
<img src="<%= dairy.displayImage %>" class="avatar-img">
</div>

<div class="profile-right">

<h2>
<% if (user?.role === 'admin') { %>
<span class="editable" data-field="name"><%= dairy.name %></span>
<% } else { %>
<%= dairy.name %>
<% } %>
</h2>

<div class="meta">
<strong>Code:</strong>
<% if (user?.role === 'admin') { %>
<span class="editable" data-field="code"><%= dairy.code %></span>
<% } else { %>
<%= dairy.code %>
<% } %>
</div>

<% if (dairy.hasIdentity) { %>
<div class="meta"><strong>Gender:</strong> <%= dairy.gender %></div>
<div class="meta"><strong>Age:</strong> <%= dairy.ageText %></div>
<% } %>

<div class="meta">
<strong>Mass:</strong>
<% if (user?.role === 'admin') { %>
<span class="editable" data-field="mass"><%= dairy.mass %></span>
<% } else { %>
<%= dairy.mass %>
<% } %> Kgs
</div>

<% if (dairy.isFemale) { %>
<div class="meta">
<strong>Status:</strong>
<span class="badge <%= dairy.isMilking ? 'bg-success' : 'bg-secondary' %>">
<%= dairy.isMilkingText %>
</span>
</div>

<div class="meta" style="margin-top:8px;">
<a href="/milk/history/<%= dairy._id %>" class="btn btn-primary btn-sm">
🍼 View Milking History
</a>
</div>
<% } %>

</div>
</div>

<% if (user?.role === 'admin') { %>
<div class="actions">
<form action="/dairy/<%= dairy._id %>?_method=DELETE" method="POST">
<button class="btn btn-danger">Delete Profile</button>
</form>
</div>
<% } %>

</div>


<!-- ========================= -->
<!-- CREATE POST -->
<!-- ========================= -->

<% if (user) { %>
<div class="card mt-3 p-3">

<form id="postForm" enctype="multipart/form-data">

<textarea 
id="postText"
placeholder="<%= user.name %>, say something about this project..."
rows="2"
required
></textarea>

<input type="file" id="postImage" accept="image/*">

<button type="submit" class="btn btn-success mt-2">Post</button>

</form>

</div>
<% } %>


<!-- ========================= -->
<!-- FEED -->
<!-- ========================= -->

<div id="postFeed">

<% posts.forEach(post => { %>

<div class="feed-card" data-id="<%= post._id %>">

<div class="feed-header">
<strong><%= post.userName %></strong>
<small><%= post.dateText %></small>

<% if (user && (user._id.toString() === post.userId.toString() || user.role === 'admin')) { %>
<button class="delete-post" data-id="<%= post._id %>">🗑</button>
<% } %>

</div>

<div class="feed-body">
<p><%= post.text %></p>

<% if (post.image) { %>
<img src="/uploads/<%= post.image %>" class="feed-img">
<% } %>
</div>

<div class="feed-actions">

<button class="like-btn" data-id="<%= post._id %>">
👍 <span class="like-count"><%= post.likes %></span>
</button>

<button class="toggle-comments">
💬 <span><%= post.comments.length %></span>
</button>

</div>

<div class="comment-section">

<% post.comments.forEach(c => { %>
<div class="comment-item" data-id="<%= c._id %>">
<strong><%= c.userName %></strong><br>
<%= c.text %>

<% if (user && (user._id.toString() === c.userId.toString() || user.role === 'admin' || user._id.toString() === post.userId.toString())) { %>
<button class="delete-comment" data-id="<%= c._id %>">❌</button>
<% } %>

</div>
<% }) %>

<% if (user) { %>
<form class="comment-form" data-id="<%= post._id %>">
<textarea required></textarea>
<button type="submit">Post</button>
</form>
<% } %>

</div>

</div>

<% }) %>

</div>


<!-- ========================= -->
<!-- MEDICAL FEED -->
<!-- ========================= -->

<% if (dairy.medicalAttention && dairy.medicalAttention.isMarked) { %>

<div id="medicalFeed" class="medical-feed-card">

<div class="feed-header">
<strong><%= user?.name || 'System' %></strong>
<small><%= new Date(dairy.medicalAttention.markedAt).toLocaleString() %></small>
</div>

<div class="feed-body">
<div class="feed-title">🚨 Medical Attention Required</div>
<div>
<strong>Type:</strong> <%= dairy.medicalAttention.type %><br>
<strong>Details:</strong> <%= dairy.medicalAttention.details %>
</div>
</div>

<div class="feed-actions">
👍 <span id="medicalLikeCount"><%= dairy.medicalAttention.likes || 0 %></span>
💬 <span><%= commentCount %></span>
</div>

</div>

<% } %>

</div>


<!-- ========================= -->
<!-- STYLES -->
<!-- ========================= -->

<style>

.feed-card{
background:#fff;
padding:12px;
margin-top:12px;
border-radius:10px;
box-shadow:0 3px 8px rgba(0,0,0,.08);
}

.feed-img{
width:100%;
border-radius:8px;
margin-top:8px;
}

.feed-actions{
display:flex;
gap:10px;
margin-top:8px;
}

.feed-actions button{
border:none;
background:none;
cursor:pointer;
}

.comment-section{
display:none;
margin-top:10px;
}

.comment-section.active{
display:block;
}

.delete-post,
.delete-comment{
color:red;
border:none;
background:none;
cursor:pointer;
float:right;
}

.medical-feed-card{
background:#fff;
border-left:5px solid #c62828;
padding:12px;
margin-top:15px;
border-radius:10px;
box-shadow:0 4px 10px rgba(0,0,0,.08);
}

</style>


<!-- ========================= -->
<!-- SOCKET + REALTIME LOGIC -->
<!-- ========================= -->

<script>

const dairyId = "<%= dairy._id %>";
const socket = io();

socket.emit("joinDairy", dairyId);

<% if (user) { %>
socket.emit("setUser", {
  _id: "<%= user._id %>",
  name: "<%= user.name %>",
  role: "<%= user.role %>"
});
<% } %>


/* =========================
   CREATE POST
========================= */
document.getElementById("postForm")?.addEventListener("submit", async e => {
  e.preventDefault();

  const text = document.getElementById("postText").value;
  const image = document.getElementById("postImage").files[0];

  const formData = new FormData();
  formData.append("text", text);
  if (image) formData.append("image", image);

  await fetch(`/dairy/${dairyId}/post`, {
    method: "POST",
    body: formData
  });

  document.getElementById("postText").value = "";
  document.getElementById("postImage").value = "";
});


/* =========================
   LIKE POST
========================= */
document.addEventListener("click", async (e) => {
  if (e.target.closest(".like-btn")) {
    const postId = e.target.closest(".like-btn").dataset.id;

    await fetch(`/post/${postId}/like`, { method: "POST" });
  }
});


/* =========================
   TOGGLE COMMENTS
========================= */
document.addEventListener("click", (e) => {
  if (e.target.closest(".toggle-comments")) {
    const card = e.target.closest(".feed-card");
    card.querySelector(".comment-section").classList.toggle("active");
  }
});


/* =========================
   COMMENT POST
========================= */
document.addEventListener("submit", async (e) => {
  if (e.target.classList.contains("comment-form")) {
    e.preventDefault();

    const postId = e.target.dataset.id;
    const text = e.target.querySelector("textarea").value;

    await fetch(`/post/${postId}/comment`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ text })
    });

    e.target.querySelector("textarea").value = "";
  }
});


/* =========================
   DELETE POST
========================= */
document.addEventListener("click", async (e) => {
  if (e.target.classList.contains("delete-post")) {
    const id = e.target.dataset.id;
    await fetch(`/post/${id}`, { method: "DELETE" });
  }
});


/* =========================
   DELETE COMMENT
========================= */
document.addEventListener("click", async (e) => {
  if (e.target.classList.contains("delete-comment")) {
    const id = e.target.dataset.id;
    await fetch(`/comment/${id}`, { method: "DELETE" });
  }
});


/* =========================
   SOCKET EVENTS
========================= */

/* NEW POST */
socket.on("postCreated", (post) => {

  const feed = document.getElementById("postFeed");

  const div = document.createElement("div");
  div.className = "feed-card";
  div.dataset.id = post._id;

  div.innerHTML = `
    <div class="feed-header">
      <strong>${post.userName}</strong>
      <small>${post.dateText}</small>
    </div>

    <div class="feed-body">
      <p>${post.text || ''}</p>
      ${post.image ? `<img src="/uploads/${post.image}" class="feed-img">` : ''}
    </div>

    <div class="feed-actions">
      <button class="like-btn" data-id="${post._id}">
        👍 <span class="like-count">0</span>
      </button>

      <button class="toggle-comments">💬 <span>0</span></button>
    </div>

    <div class="comment-section"></div>
  `;

  feed.prepend(div);
});


/* LIKE UPDATE */
socket.on("postLiked", (data) => {
  const el = document.querySelector(`[data-id="${data.postId}"] .like-count`);
  if (el) el.textContent = data.likes;
});


/* NEW COMMENT */
socket.on("postCommentAdded", (data) => {
  const card = document.querySelector(`[data-id="${data.postId}"] .comment-section`);
  if (!card) return;

  const div = document.createElement("div");
  div.className = "comment-item";
  div.innerHTML = `<strong>${data.comment.userName}</strong><br>${data.comment.text}`;

  card.appendChild(div);
});


/* DELETE POST */
socket.on("postDeleted", (data) => {
  const el = document.querySelector(`[data-id="${data.postId}"]`);
  if (el) el.remove();
});


/* DELETE COMMENT */
socket.on("commentDeleted", (data) => {
  const el = document.querySelector(`[data-id="${data.commentId}"]`);
  if (el) el.remove();
});

</script>
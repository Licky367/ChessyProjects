<script src="/socket.io/socket.io.js"></script>

<div class="container mt-4">

<!-- ========================= -->
<!-- PROFILE CARD -->
<!-- ========================= -->

<div class="card">

<div class="profile-top">

<div class="profile-left">
<img src="<%= dairy.displayImage %>" class="avatar-img">
</div>

<div class="profile-right">

<h2>
<% if (user?.role === 'admin') { %>
<span class="editable" data-field="name"><%= dairy.name %></span>
<% } else { %>
<%= dairy.name %>
<% } %>
</h2>

<div class="meta">
<strong>Code:</strong>
<% if (user?.role === 'admin') { %>
<span class="editable" data-field="code"><%= dairy.code %></span>
<% } else { %>
<%= dairy.code %>
<% } %>
</div>

<% if (dairy.hasIdentity) { %>
<div class="meta"><strong>Gender:</strong> <%= dairy.gender %></div>
<div class="meta"><strong>Age:</strong> <%= dairy.ageText %></div>
<% } %>

<div class="meta">
<strong>Mass:</strong>
<% if (user?.role === 'admin') { %>
<span class="editable" data-field="mass"><%= dairy.mass %></span>
<% } else { %>
<%= dairy.mass %>
<% } %> Kgs
</div>

<% if (dairy.isFemale) { %>
<div class="meta">
<strong>Status:</strong>
<span class="badge <%= dairy.isMilking ? 'bg-success' : 'bg-secondary' %>">
<%= dairy.isMilkingText %>
</span>
</div>

<div class="meta">
<a href="/milk/history/<%= dairy._id %>" class="btn btn-primary btn-sm">
🍼 View Milking History
</a>
</div>
<% } %>

</div>
</div>

<% if (user?.role === 'admin') { %>
<div class="actions">
<form action="/dairy/<%= dairy._id %>?_method=DELETE" method="POST">
<button class="btn btn-danger">Delete Profile</button>
</form>
</div>
<% } %>

</div>


<!-- ========================= -->
<!-- CREATE POST -->
<!-- ========================= -->

<% if (user) { %>
<div class="card mt-3 p-3">

<form id="postForm" enctype="multipart/form-data">

<textarea id="postText"
placeholder="<%= user.name %>, say something..."
rows="2"
required></textarea>

<input type="file" id="postImage" accept="image/*">

<button type="submit" class="btn btn-success mt-2">Post</button>

</form>

</div>
<% } %>


<!-- ========================= -->
<!-- FEED -->
<!-- ========================= -->

<div id="feed">

<% feed.forEach(item => { %>


<!-- ================= POST ================= -->
<% if (item.type === 'post') { %>

<div class="feed-card" data-id="<%= item._id %>">

<div class="feed-header">

<div class="feed-user">
<img src="<%= item.userImage %>" class="avatar-sm">
<div>
<strong><%= item.userName %></strong>
<small><%= item.dateText %></small>
</div>
</div>

<% if (user && (user._id.toString() === item.userId.toString() || user.role === 'admin')) { %>
<button class="delete-post" data-id="<%= item._id %>">🗑</button>
<% } %>

</div>

<div class="feed-body">
<p><%= item.text %></p>

<% if (item.image) { %>
<img src="/uploads/<%= item.image %>" class="feed-img">
<% } %>
</div>

<div class="feed-actions">
<button class="like-btn" data-id="<%= item._id %>">
👍 <span><%= item.likes %></span>
</button>

<button class="toggle-comments">
💬 <span><%= item.comments.length %></span>
</button>
</div>

<div class="comment-section">

<% item.comments.forEach(c => { %>

<div class="comment-item">

<div class="comment-user">
<img src="<%= c.userImage %>" class="avatar-xs">
<div>
<strong><%= c.userName %></strong><br>
<%= c.text %>
</div>
</div>

<% if (user) { %>
<button class="delete-comment" data-id="<%= c._id %>">❌</button>
<% } %>

</div>

<% }) %>

<% if (user) { %>
<form class="comment-form" data-id="<%= item._id %>">
<textarea required></textarea>
<button type="submit">Post</button>
</form>
<% } %>

</div>

</div>

<% } %>


<!-- ================= MILK ================= -->
<% if (item.type === 'milk') { %>

<div class="feed-card system">

<div class="feed-header">

<div class="feed-user">
<img src="<%= item.userImage %>" class="avatar-sm">
<div>
<strong><%= item.userName %></strong>
<small><%= item.dateText %></small>
</div>
</div>

</div>

<div class="feed-body">

<strong>📊 Weekly Milk Report</strong>
<p><%= item.title %></p>

<table class="weekly-table">
<thead>
<tr>
<th>Day</th>
<th>Total (L)</th>
</tr>
</thead>
<tbody>

<% item.days.forEach(d => { %>
<tr>
<td><%= d.day %></td>
<td><%= d.total %> L</td>
</tr>
<% }) %>

</tbody>
</table>

<div class="weekly-average">
Average: <%= item.average %> L/day
</div>

</div>

</div>

<% } %>


<!-- ================= MEDICAL ================= -->
<% if (item.type === 'medical') { %>

<div class="feed-card medical">

<div class="feed-header">

<div class="feed-user">
<img src="<%= item.userImage %>" class="avatar-sm">
<div>
<strong><%= item.title %></strong>
<small><%= item.dateText %></small>
</div>
</div>

</div>

<div class="feed-body">
<p><%= item.details || item.description %></p>
</div>

</div>

<% } %>


<!-- ================= MAINTENANCE ================= -->
<% if (item.type === 'maintenance') { %>

<div class="feed-card maintenance">

<div class="feed-header">

<div class="feed-user">
<img src="<%= item.userImage %>" class="avatar-sm">

<div>

<strong>
<% if (item.status === 'marked') { %>
🔧 Maintenance Required
<% } else { %>
✅ Maintenance Cleared
<% } %>
</strong>

<small><%= item.dateText %></small>

</div>

</div>

</div>

<div class="feed-body">

<% if (item.status === 'marked') { %>

<p><strong>Type:</strong> <%= item.maintenanceType %></p>
<p><%= item.description %></p>

<% } else { %>

<p><strong>Charges:</strong> KES <%= item.charges %></p>
<p><%= item.description %></p>

<% } %>

</div>

</div>

<% } %>


<% }) %>

</div>

</div>


<!-- ========================= -->
<!-- STYLES -->
<!-- ========================= -->

<style>

.feed-card{
background:#fff;
padding:12px;
margin-top:12px;
border-radius:10px;
box-shadow:0 3px 8px rgba(0,0,0,.08);
}

.feed-card.system{ border-left:5px solid #198754; }
.feed-card.medical{ border-left:5px solid #c62828; }
.feed-card.maintenance{ border-left:5px solid #6f42c1; }

.feed-header{
display:flex;
justify-content:space-between;
align-items:center;
}

.feed-user{
display:flex;
gap:10px;
align-items:center;
}

.avatar-sm{
width:40px;
height:40px;
border-radius:50%;
}

.avatar-xs{
width:28px;
height:28px;
border-radius:50%;
}

.feed-img{
width:100%;
border-radius:8px;
margin-top:8px;
}

.feed-actions{
display:flex;
gap:10px;
margin-top:8px;
}

.feed-actions button{
border:none;
background:none;
cursor:pointer;
}

.comment-section{
display:none;
margin-top:10px;
}

.comment-section.active{
display:block;
}

.delete-post,
.delete-comment{
color:red;
border:none;
background:none;
cursor:pointer;
float:right;
}

.weekly-table{
width:100%;
border-collapse:collapse;
margin-top:10px;
}

.weekly-table th,
.weekly-table td{
border:1px solid #ddd;
padding:6px;
}

.weekly-average{
margin-top:8px;
font-weight:bold;
color:#2e7d32;
}

</style>
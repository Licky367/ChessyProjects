<script src="/socket.io/socket.io.js"></script>

<div class="container mt-4">

<!-- ========================= -->
<!-- PROFILE CARD (UNCHANGED) -->
<!-- ========================= -->

<div class="card">

<div class="profile-top">

<div class="profile-left">
<img src="<%= dairy.displayImage %>" class="avatar-img">
</div>

<div class="profile-right">

<h2>
<% if (user?.role === 'admin') { %>
<span class="editable" data-field="name"><%= dairy.name %></span>
<% } else { %>
<%= dairy.name %>
<% } %>
</h2>

<div class="meta">
<strong>Code:</strong>
<% if (user?.role === 'admin') { %>
<span class="editable" data-field="code"><%= dairy.code %></span>
<% } else { %>
<%= dairy.code %>
<% } %>
</div>

<% if (dairy.hasIdentity) { %>
<div class="meta"><strong>Gender:</strong> <%= dairy.gender %></div>
<div class="meta"><strong>Age:</strong> <%= dairy.ageText %></div>
<% } %>

<div class="meta">
<strong>Mass:</strong>
<% if (user?.role === 'admin') { %>
<span class="editable" data-field="mass"><%= dairy.mass %></span>
<% } else { %>
<%= dairy.mass %>
<% } %>
Kgs
</div>

<% if (dairy.isFemale) { %>
<div class="meta">
<strong>Status:</strong>
<span class="badge <%= dairy.isMilking ? 'bg-success' : 'bg-secondary' %>">
<%= dairy.isMilkingText %>
</span>
</div>

<div class="meta" style="margin-top:8px;">
<a href="/milk/history/<%= dairy._id %>" class="btn btn-primary btn-sm">
🍼 View Milking History
</a>
</div>
<% } %>

</div>
</div>

<% if (user?.role === 'admin') { %>
<div class="actions">
<form action="/dairy/<%= dairy._id %>?_method=DELETE" method="POST">
<button class="btn btn-danger">Delete Profile</button>
</form>
</div>
<% } %>

</div>


<!-- ========================= -->
<!-- 🟦 CREATE POST -->
<!-- ========================= -->

<% if (user) { %>
<div class="card mt-3 p-3">

<form id="postForm" enctype="multipart/form-data">
<textarea 
id="postText" 
placeholder="<%= user.name %>, say something about this project..."
rows="2"
required
></textarea>

<input type="file" id="postImage" accept="image/*">

<button type="submit" class="btn btn-success mt-2">Post</button>
</form>

</div>
<% } %>


<!-- ========================= -->
<!-- 🟦 GENERAL FEED -->
<!-- ========================= -->

<div id="postFeed">

<% if (posts && posts.length) { %>
<% posts.forEach(post => { %>

<div class="feed-card" data-id="<%= post._id %>">

<div class="feed-header">
<strong><%= post.userName %></strong>
<small><%= post.dateText %></small>

<% if (
user && 
(user._id.toString() === post.userId.toString() || user.role === 'admin')
) { %>
<button class="delete-post" data-id="<%= post._id %>">🗑</button>
<% } %>
</div>

<div class="feed-body">
<p><%= post.text %></p>

<% if (post.image) { %>
<img src="/uploads/<%= post.image %>" class="feed-img">
<% } %>
</div>

<div class="feed-actions">

<button class="like-btn" data-id="<%= post._id %>">
👍 <span class="like-count"><%= post.likes %></span>
</button>

<button class="toggle-comments">
💬 <span><%= post.comments.length %></span>
</button>

</div>

<div class="comment-section">

<% post.comments.forEach(c => { %>
<div class="comment-item">
<strong><%= c.userName %></strong><br>
<%= c.text %>

<% if (
user &&
(
user._id.toString() === c.userId.toString() ||
user._id.toString() === post.userId.toString() ||
user.role === 'admin'
)
) { %>
<button class="delete-comment" data-id="<%= c._id %>">❌</button>
<% } %>
</div>
<% }) %>

<% if (user) { %>
<form class="comment-form" data-id="<%= post._id %>">
<textarea required></textarea>
<button type="submit">Post</button>
</form>
<% } %>

</div>

</div>

<% }) %>
<% } %>

</div>


<!-- ========================= -->
<!-- 🟥 MEDICAL FEED -->
<!-- ========================= -->

<% if (dairy.medicalAttention && dairy.medicalAttention.isMarked) { %>

<div id="medicalFeed" class="medical-feed-card">

<div class="feed-header">
<div class="feed-avatar">
<img src="https://ui-avatars.com/api/?name=<%= user?.name || 'System' %>&background=c62828&color=fff">
</div>

<div class="feed-meta">
<strong><%= user?.name || 'System Update' %></strong>
<div class="feed-time">
<%= new Date(dairy.medicalAttention.markedAt).toLocaleString() %>
</div>
</div>
</div>

<div class="feed-body">
<div class="feed-title">🚨 Medical Attention Required</div>

<div class="feed-content">
<strong>Type:</strong> <%= dairy.medicalAttention.type %><br>
<strong>Details:</strong> <%= dairy.medicalAttention.details %>
</div>
</div>

<div class="feed-actions">
👍 <span id="medicalLikeCount"><%= dairy.medicalAttention.likes || 0 %></span>
💬 <span id="commentCount"><%= commentCount %></span>
</div>

<div id="commentSection" class="comment-section">
<div id="commentsContainer">

<% updates.forEach(item => { %>
<div class="comment-item">
<strong><%= item.userName %></strong><br>
<%= item.comment %>
</div>
<% }) %>

</div>

<% if (user) { %>
<form id="commentForm" class="comment-box">
<textarea id="commentInput" rows="2" required></textarea>
<button type="submit">Post</button>
</form>
<% } %>

</div>

</div>

<% } %>

</div>


<!-- ========================= -->
<!-- STYLES -->
<!-- ========================= -->

<style>

.feed-card{
background:#fff;
padding:12px;
margin-top:12px;
border-radius:10px;
box-shadow:0 3px 8px rgba(0,0,0,.08);
}

.feed-img{
width:100%;
border-radius:8px;
margin-top:8px;
}

.feed-actions{
display:flex;
gap:10px;
margin-top:8px;
}

.feed-actions button{
border:none;
background:none;
cursor:pointer;
}

.comment-section{
display:none;
margin-top:10px;
}

.comment-section.active{
display:block;
}

.delete-post,
.delete-comment{
color:red;
border:none;
background:none;
cursor:pointer;
float:right;
}

.medical-feed-card{
background:#fff;
border-left:5px solid #c62828;
border-radius:10px;
padding:12px;
margin-top:15px;
box-shadow:0 4px 10px rgba(0,0,0,.08);
}

</style>


<!-- ========================= -->
<!-- JAVASCRIPT -->
<!-- ========================= -->

<script>

const dairyId = "<%= dairy._id %>";

/* CREATE POST */
document.getElementById("postForm")?.addEventListener("submit", async e=>{
e.preventDefault();

const formData = new FormData();
formData.append("text", document.getElementById("postText").value);
formData.append("image", document.getElementById("postImage").files[0]);

await fetch(`/dairy/${dairyId}/post`,{
method:"POST",
body:formData
});

location.reload();
});


/* LIKE */
document.querySelectorAll(".like-btn").forEach(btn=>{
btn.addEventListener("click", async ()=>{
await fetch(`/post/${btn.dataset.id}/like`,{method:"POST"});
location.reload();
});
});


/* TOGGLE COMMENTS */
document.querySelectorAll(".toggle-comments").forEach(btn=>{
btn.addEventListener("click", ()=>{
btn.closest(".feed-card")
.querySelector(".comment-section")
.classList.toggle("active");
});
});


/* COMMENT POST */
document.querySelectorAll(".comment-form").forEach(form=>{
form.addEventListener("submit", async e=>{
e.preventDefault();

const postId = form.dataset.id;
const text = form.querySelector("textarea").value;

await fetch(`/post/${postId}/comment`,{
method:"POST",
headers:{ "Content-Type":"application/json" },
body: JSON.stringify({ text })
});

location.reload();
});
});


/* DELETE POST */
document.querySelectorAll(".delete-post").forEach(btn=>{
btn.addEventListener("click", async ()=>{
await fetch(`/post/${btn.dataset.id}`,{method:"DELETE"});
location.reload();
});
});


/* DELETE COMMENT */
document.querySelectorAll(".delete-comment").forEach(btn=>{
btn.addEventListener("click", async ()=>{
await fetch(`/comment/${btn.dataset.id}`,{method:"DELETE"});
location.reload();
});
});

</script>
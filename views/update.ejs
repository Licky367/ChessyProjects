<!-- views/update.ejs -->

<script src="/socket.io/socket.io.js"></script>

<div class="container mt-4">

<div class="card">

<!-- PROFILE TOP -->
<div class="profile-top">

<!-- LEFT -->
<div class="profile-left">

<img
src="<%= dairy.displayImage %>"
alt="<%= dairy.name %>"
id="profilePreview"
class="avatar-img"
>

</div>

<!-- RIGHT -->
<div class="profile-right">

<div class="name-row">
<h2>

<% if (user?.role === 'admin') { %>
<span class="editable" data-field="name" data-value="<%= dairy.name %>">
<%= dairy.name %>
</span>
<% } else { %>
<%= dairy.name %>
<% } %>

</h2>
</div>

<div class="meta">
<strong>Code:</strong>

<% if (user?.role === 'admin') { %>
<span class="editable" data-field="code" data-value="<%= dairy.code %>">
<%= dairy.code %>
</span>
<% } else { %>
<%= dairy.code %>
<% } %>

</div>

<% if (dairy.hasIdentity) { %>
<div class="meta"><strong>Gender:</strong> <%= dairy.gender %></div>
<div class="meta"><strong>Age:</strong> <%= dairy.ageText %></div>
<% } %>

<div class="meta">
<strong>Mass:</strong>

<% if (user?.role === 'admin') { %>
<span class="editable" data-field="mass" data-value="<%= dairy.mass %>">
<%= dairy.mass %>
</span>
<% } else { %>
<%= dairy.mass %>
<% } %>

Kgs
</div>

<% if (dairy.isFemale) { %>
<div class="meta">

<strong>Status:</strong>

<% if (user?.role === 'admin') { %>

<label>
<input type="checkbox" id="milkingToggle" <%= dairy.isMilking ? 'checked' : '' %>>

<span id="milkBadge" class="badge <%= dairy.isMilking ? 'bg-success' : 'bg-secondary' %>">
<%= dairy.isMilkingText %>
</span>
</label>

<% } else { %>

<span class="badge <%= dairy.isMilking ? 'bg-success' : 'bg-secondary' %>">
<%= dairy.isMilkingText %>
</span>

<% } %>

</div>
<% } %>

</div>
</div>

<!-- DELETE -->
<% if (user?.role === 'admin') { %>
<div class="actions">
<form action="/dairy/<%= dairy._id %>?_method=DELETE" method="POST">
<button class="btn btn-danger">Delete Profile</button>
</form>
</div>
<% } %>

</div>
</div>

<!-- ========================= -->
<!-- IMAGE ACTION SHEET -->
<!-- ========================= -->
<div class="fb-sheet" id="imageSheet">

<button onclick="openGallery()">👁 View Photo</button>

<% if (user?.role === 'admin') { %>

<button onclick="document.getElementById('imageInput').click()">
📷 Change Photo
</button>

<form action="/dairy/<%= dairy._id %>/image?_method=DELETE" method="POST">
<button type="submit">🗑 Delete Photo</button>
</form>

<% } %>

<button onclick="closeSheet()">Cancel</button>

</div>

<!-- ========================= -->
<!-- GALLERY MODAL -->
<!-- ========================= -->
<div class="modal fade" id="viewImageModal" tabindex="-1">
<div class="modal-dialog modal-dialog-centered modal-xl">
<div class="modal-content border-0">

<div class="gallery-box">

<button class="gallery-nav gallery-prev" onclick="prevImage()">‹</button>

<img id="galleryImage" class="gallery-img" src="">

<button class="gallery-nav gallery-next" onclick="nextImage()">›</button>

<!-- COMMENT ICON -->
<button
class="btn btn-light rounded-circle"
style="position:absolute;bottom:20px;right:20px;width:55px;height:55px;"
data-bs-toggle="modal"
data-bs-target="#commentsModal"
>
💬
</button>

</div>
</div>
</div>
</div>

<!-- ========================= -->
<!-- COMMENTS MODAL (SOCKET ENABLED) -->
<!-- ========================= -->
<div class="modal fade" id="commentsModal" tabindex="-1">
<div class="modal-dialog">
<div class="modal-content">

<div class="modal-header">
<h5 class="modal-title">Comments</h5>
<button class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body">

<!-- LIVE COMMENTS CONTAINER -->
<div id="commentsContainer">

<% if (updates.length) { %>

<% updates.forEach(item => { %>
<div class="comment-item">
<strong><%= item.userName %></strong><br>
<%= item.comment %><br>
<small><%= item.dateText %></small>
</div>
<% }) %>

<% } else { %>
<p id="noComments">No comments yet.</p>
<% } %>

</div>

<% if (user) { %>
<form id="commentForm" class="comment-box">
<textarea name="comment" id="commentInput" rows="2" required></textarea>
<button class="btn btn-primary">Post</button>
</form>
<% } %>

</div>
</div>
</div>
</div>

<!-- ========================= -->
<!-- IMAGE UPLOAD -->
<!-- ========================= -->
<form
id="uploadForm"
action="/dairy/<%= dairy._id %>/image?_method=PUT"
method="POST"
enctype="multipart/form-data"
style="display:none;"
>
<input type="file" name="profileImage" id="imageInput"
accept="image/*"
onchange="document.getElementById('uploadForm').submit()">
</form>

<!-- ========================= -->
<!-- SOCKET + JS -->
<!-- ========================= -->
<script>

const dairyId = "<%= dairy._id %>";
const userId = "<%= user?._id %>";
const userName = "<%= user?.name %>";

/* SOCKET INIT */
const socket = io();

/* JOIN ROOM */
socket.emit("joinDairy", dairyId);

/* RECEIVE LIVE COMMENTS */
socket.on("commentAdded", (data) => {

const container = document.getElementById("commentsContainer");

const div = document.createElement("div");
div.className = "comment-item";

div.innerHTML = `
<strong>${data.userName}</strong><br>
${data.comment}<br>
<small>${data.dateText}</small>
`;

container.prepend(div);

const noComments = document.getElementById("noComments");
if(noComments) noComments.remove();
});

/* SEND COMMENT */
document.getElementById("commentForm")?.addEventListener("submit", (e) => {
e.preventDefault();

const commentInput = document.getElementById("commentInput");

socket.emit("newComment", {
dairyId,
userId,
userName,
comment: commentInput.value
});

commentInput.value = "";
});

/* IMAGE LIST */
const images = ["<%= dairy.displayImage %>"];
let currentIndex = 0;

/* ACTION SHEET */
document.getElementById("profilePreview")
.addEventListener("click", () => {
document.getElementById("imageSheet").classList.add("show");
});

function closeSheet(){
document.getElementById("imageSheet").classList.remove("show");
}

/* GALLERY */
function openGallery(){
closeSheet();
document.getElementById("galleryImage").src = images[currentIndex];

new bootstrap.Modal(
document.getElementById("viewImageModal")
).show();
}

function nextImage(){
currentIndex = (currentIndex + 1) % images.length;
document.getElementById("galleryImage").src = images[currentIndex];
}

function prevImage(){
currentIndex = (currentIndex - 1 + images.length) % images.length;
document.getElementById("galleryImage").src = images[currentIndex];
}

/* INLINE EDIT */
document.querySelectorAll(".editable").forEach(el => {
el.addEventListener("click", function(){

const field = this.dataset.field;
const current = this.dataset.value;

const value = prompt("Update " + field, current);
if(value === null) return;

document.getElementById("editField").value = field;
document.getElementById("editValue").value = value;

const form = document.getElementById("inlineEditForm");
form.action = "/dairy/<%= dairy._id %>";
form.submit();

});
});

/* MILKING */
document.getElementById("milkingToggle")
?.addEventListener("change", function(){

fetch("/dairy/<%= dairy._id %>/milking",{
method:"POST",
headers:{ "Content-Type":"application/json" },
body:JSON.stringify({ isMilking:this.checked })
});

const badge = document.getElementById("milkBadge");

if(this.checked){
badge.innerText = "Being Milked";
badge.classList.add("bg-success");
badge.classList.remove("bg-secondary");
}else{
badge.innerText = "Not Milked";
badge.classList.add("bg-secondary");
badge.classList.remove("bg-success");
}

});

</script>
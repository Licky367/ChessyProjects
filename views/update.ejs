<script src="/socket.io/socket.io.js"></script>

<div class="container mt-4">

<!-- ========================= -->
<!-- PROFILE CARD -->
<!-- ========================= -->

<div class="card">

<div class="profile-top">

<div class="profile-left">
<img src="<%= dairy.displayImage %>" class="avatar-img">
</div>

<div class="profile-right">

<h2>
<% if (user?.role === 'admin') { %>
<span class="editable" data-field="name"><%= dairy.name %></span>
<% } else { %>
<%= dairy.name %>
<% } %>
</h2>

<div class="meta">
<strong>Code:</strong>
<% if (user?.role === 'admin') { %>
<span class="editable" data-field="code"><%= dairy.code %></span>
<% } else { %>
<%= dairy.code %>
<% } %>
</div>

<% if (dairy.hasIdentity) { %>
<div class="meta"><strong>Gender:</strong> <%= dairy.gender %></div>
<div class="meta"><strong>Age:</strong> <%= dairy.ageText %></div>
<% } %>

<div class="meta">
<strong>Mass:</strong>
<% if (user?.role === 'admin') { %>
<span class="editable" data-field="mass"><%= dairy.mass %></span>
<% } else { %>
<%= dairy.mass %>
<% } %> Kgs
</div>

<% if (dairy.isFemale) { %>
<div class="meta">
<strong>Status:</strong>
<span class="badge <%= dairy.isMilking ? 'bg-success' : 'bg-secondary' %>">
<%= dairy.isMilkingText %>
</span>
</div>

<div class="meta" style="margin-top:8px;">
<a href="/milk/history/<%= dairy._id %>" class="btn btn-primary btn-sm">
🍼 View Milking History
</a>
</div>
<% } %>

</div>
</div>

<% if (user?.role === 'admin') { %>
<div class="actions">
<form action="/dairy/<%= dairy._id %>?_method=DELETE" method="POST">
<button class="btn btn-danger">Delete Profile</button>
</form>
</div>
<% } %>

</div>


<!-- ========================= -->
<!-- CREATE POST -->
<!-- ========================= -->

<% if (user) { %>
<div class="card mt-3 p-3">

<form id="postForm" enctype="multipart/form-data">

<textarea 
id="postText"
placeholder="<%= user.name %>, say something about this project..."
rows="2"
required
></textarea>

<input type="file" id="postImage" accept="image/*">

<button type="submit" class="btn btn-success mt-2">Post</button>

</form>

</div>
<% } %>


<!-- ========================= -->
<!-- FEED -->
<!-- ========================= -->

<div id="postFeed">

<% posts.forEach(post => { %>

<div class="feed-card" data-id="<%= post._id %>">

<div class="feed-header">

<div class="feed-user">
<img src="<%= post.userImage || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(post.userName) %>" class="avatar-sm">
<div>
<strong><%= post.userName %></strong>
<small><%= post.dateText %></small>
</div>
</div>

<% if (user && (user._id.toString() === post.userId.toString() || user.role === 'admin')) { %>
<button class="delete-post" data-id="<%= post._id %>">🗑</button>
<% } %>

</div>

<div class="feed-body">
<p><%= post.text %></p>

<% if (post.image) { %>
<img src="/uploads/<%= post.image %>" class="feed-img">
<% } %>
</div>

<div class="feed-actions">

<button class="like-btn" data-id="<%= post._id %>">
👍 <span class="like-count"><%= post.likes %></span>
</button>

<button class="toggle-comments">
💬 <span><%= post.comments.length %></span>
</button>

</div>

<div class="comment-section">

<% post.comments.forEach(c => { %>
<div class="comment-item" data-id="<%= c._id %>">

<div class="comment-user">
<img src="<%= c.userImage || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(c.userName) %>" class="avatar-xs">
<div>
<strong><%= c.userName %></strong><br>
<%= c.text %>
</div>
</div>

<% if (user && (user._id.toString() === c.userId.toString() || user.role === 'admin' || user._id.toString() === post.userId.toString())) { %>
<button class="delete-comment" data-id="<%= c._id %>">❌</button>
<% } %>

</div>
<% }) %>

<% if (user) { %>
<form class="comment-form" data-id="<%= post._id %>">
<textarea required></textarea>
<button type="submit">Post</button>
</form>
<% } %>

</div>

</div>

<% }) %>

</div>


<!-- ========================= -->
<!-- 🟩 WEEKLY MILKING FEED -->
<!-- ========================= -->

<% if (weeklyFeed) { %>

<div class="feed-card">

<div class="feed-header">

<div class="feed-user">
<img src="https://ui-avatars.com/api/?name=System&background=198754&color=fff" class="avatar-sm">
<div>
<strong>System</strong>
<small><%= weeklyFeed.weekEndText %></small>
</div>
</div>

</div>

<div class="feed-body">

<div class="feed-title">
📊 Weekly milking summary of <%= dairy.name %><br>
<small><%= weeklyFeed.weekStart %> → <%= weeklyFeed.weekEnd %></small>
</div>

<table class="weekly-table">
<thead>
<tr>
<th>Day</th>
<th>Total (L)</th>
</tr>
</thead>
<tbody>

<% weeklyFeed.days.forEach(d => { %>
<tr>
<td><%= d.day %></td>
<td><%= d.total %> L</td>
</tr>
<% }) %>

</tbody>
</table>

<div class="weekly-average">
Average: <strong><%= weeklyFeed.average %> L/day</strong>
</div>

</div>

</div>

<% } %>


<!-- ========================= -->
<!-- MEDICAL FEED -->
<!-- ========================= -->

<% if (dairy.medicalAttention && dairy.medicalAttention.isMarked) { %>

<div id="medicalFeed" class="medical-feed-card">

<div class="feed-header">

<div class="feed-user">
<img src="https://ui-avatars.com/api/?name=<%= user?.name || 'System' %>&background=c62828&color=fff" class="avatar-sm">
<div>
<strong><%= user?.name || 'System' %></strong>
<small><%= new Date(dairy.medicalAttention.markedAt).toLocaleString() %></small>
</div>
</div>

</div>

<div class="feed-body">
<div class="feed-title">🚨 Medical Attention Required</div>
<div>
<strong>Type:</strong> <%= dairy.medicalAttention.type %><br>
<strong>Details:</strong> <%= dairy.medicalAttention.details %>
</div>
</div>

<div class="feed-actions">
👍 <span id="medicalLikeCount"><%= dairy.medicalAttention.likes || 0 %></span>
💬 <span><%= commentCount %></span>
</div>

</div>

<% } %>

</div>


<!-- ========================= -->
<!-- STYLES -->
<!-- ========================= -->

<style>

.feed-card{
background:#fff;
padding:12px;
margin-top:12px;
border-radius:10px;
box-shadow:0 3px 8px rgba(0,0,0,.08);
}

.feed-header{
display:flex;
justify-content:space-between;
align-items:center;
}

.feed-user{
display:flex;
gap:10px;
align-items:center;
}

.avatar-sm{
width:40px;
height:40px;
border-radius:50%;
}

.avatar-xs{
width:28px;
height:28px;
border-radius:50%;
}

.feed-img{
width:100%;
border-radius:8px;
margin-top:8px;
}

.feed-actions{
display:flex;
gap:10px;
margin-top:8px;
}

.feed-actions button{
border:none;
background:none;
cursor:pointer;
}

.comment-section{
display:none;
margin-top:10px;
}

.comment-section.active{
display:block;
}

.delete-post,
.delete-comment{
color:red;
border:none;
background:none;
cursor:pointer;
float:right;
}

.medical-feed-card{
background:#fff;
border-left:5px solid #c62828;
padding:12px;
margin-top:15px;
border-radius:10px;
box-shadow:0 4px 10px rgba(0,0,0,.08);
}

.weekly-table{
width:100%;
border-collapse:collapse;
margin-top:10px;
}

.weekly-table th,
.weekly-table td{
border:1px solid #ddd;
padding:6px;
}

.weekly-average{
margin-top:8px;
font-weight:bold;
color:#2e7d32;
}

</style>
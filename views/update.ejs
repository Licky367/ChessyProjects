<script src="/socket.io/socket.io.js"></script>

<div class="container mt-4">

<div class="card">

<!-- PROFILE TOP -->
<div class="profile-top">

<div class="profile-left">
<img src="<%= dairy.displayImage %>" class="avatar-img">
</div>

<div class="profile-right">

<h2>
<% if (user?.role === 'admin') { %>
<span class="editable" data-field="name" data-value="<%= dairy.name %>">
<%= dairy.name %>
</span>
<% } else { %>
<%= dairy.name %>
<% } %>
</h2>

<div class="meta">
<strong>Code:</strong>
<% if (user?.role === 'admin') { %>
<span class="editable" data-field="code" data-value="<%= dairy.code %>">
<%= dairy.code %>
</span>
<% } else { %>
<%= dairy.code %>
<% } %>
</div>

<% if (dairy.hasIdentity) { %>
<div class="meta"><strong>Gender:</strong> <%= dairy.gender %></div>
<div class="meta"><strong>Age:</strong> <%= dairy.ageText %></div>
<% } %>

<div class="meta">
<strong>Mass:</strong>
<% if (user?.role === 'admin') { %>
<span class="editable" data-field="mass"><%= dairy.mass %></span>
<% } else { %>
<%= dairy.mass %>
<% } %>
Kgs
</div>

<% if (dairy.isFemale) { %>
<div class="meta">
<strong>Status:</strong>

<% if (user?.role === 'admin') { %>
<label>
<input type="checkbox" <%= dairy.isMilking ? 'checked' : '' %>>
<span class="badge <%= dairy.isMilking ? 'bg-success' : 'bg-secondary' %>">
<%= dairy.isMilkingText %>
</span>
</label>
<% } else { %>
<span class="badge <%= dairy.isMilking ? 'bg-success' : 'bg-secondary' %>">
<%= dairy.isMilkingText %>
</span>
<% } %>

</div>
<% } %>

</div>
</div>

<% if (user?.role === 'admin') { %>
<div class="actions">
<form action="/dairy/<%= dairy._id %>?_method=DELETE" method="POST">
<button class="btn btn-danger">Delete Profile</button>
</form>
</div>
<% } %>

</div>
</div>


<!-- ========================= -->
<!-- 🟥 MEDICAL FEED -->
<!-- ========================= -->

<% if (dairy.medicalAttention && dairy.medicalAttention.isMarked) { %>

<div id="medicalFeed" class="medical-feed-card">

  <div class="feed-header">
    <div class="feed-avatar">
      <img src="https://ui-avatars.com/api/?name=<%= user?.name || 'System' %>&background=c62828&color=fff">
    </div>

    <div class="feed-meta">
      <strong><%= user?.name || 'System Update' %></strong>
      <div class="feed-time">
        <%= dairy.medicalAttention.markedAt ? new Date(dairy.medicalAttention.markedAt).toLocaleString() : '' %>
      </div>
    </div>
  </div>

  <div class="feed-body">
    <div class="feed-title">🚨 Medical Attention Required</div>

    <div class="feed-content">
      <strong>Type:</strong> <%= dairy.medicalAttention.type %><br>
      <strong>Details:</strong> <%= dairy.medicalAttention.details %>
    </div>
  </div>

  <!-- ✅ ACTION BAR -->
  <div class="feed-actions">
    <span onclick="toggleComments()">💬 
      <span id="commentCount"><%= updates.length %></span>
    </span>
  </div>

  <!-- ✅ INLINE COMMENTS -->
  <div id="commentSection" class="comment-section">

    <div id="commentsContainer">

      <% if (updates.length) { %>
        <% updates.forEach(item => { %>
          <div class="comment-item">
            <strong><%= item.userName %></strong><br>
            <%= item.comment %><br>
            <small><%= item.dateText %></small>
          </div>
        <% }) %>
      <% } else { %>
        <p id="noComments">No comments yet.</p>
      <% } %>

    </div>

    <% if (user) { %>
    <form id="commentForm" class="comment-box">
      <textarea name="comment" id="commentInput" rows="2" required></textarea>
      <button class="btn btn-primary">Post</button>
    </form>
    <% } %>

  </div>

</div>

<% } %>


<!-- ========================= -->
<!-- STYLES -->
<!-- ========================= -->
<style>

.medical-feed-card{
background:#fff;
border-left:5px solid #c62828;
border-radius:10px;
padding:12px;
margin-top:15px;
box-shadow:0 4px 10px rgba(0,0,0,.08);
}

.feed-header{
display:flex;
gap:10px;
}

.feed-avatar img{
width:40px;height:40px;border-radius:50%;
}

.feed-title{
color:#c62828;font-weight:bold;
}

.feed-actions{
margin-top:10px;
border-top:1px solid #eee;
padding-top:8px;
cursor:pointer;
color:#555;
}

.comment-section{
max-height:0;
overflow:hidden;
transition:.3s ease;
}

.comment-section.active{
max-height:400px;
margin-top:10px;
}

.comment-item{
padding:6px 0;
border-bottom:1px solid #eee;
font-size:13px;
}

.comment-box{
display:flex;
gap:8px;
margin-top:8px;
}

.comment-box textarea{
flex:1;
padding:6px;
resize:none;
}

.comment-box button{
background:#0b5d1e;
color:#fff;
border:none;
padding:6px 10px;
border-radius:6px;
}

</style>


<!-- ========================= -->
<!-- SOCKET + JS -->
<!-- ========================= -->
<script>

const dairyId = "<%= dairy._id %>";
const socket = io();

socket.emit("joinDairy", dairyId);

/* TOGGLE COMMENTS */
function toggleComments(){
const section = document.getElementById("commentSection");
section.classList.toggle("active");
}

/* COMMENTS REALTIME */
socket.on("commentAdded", (data) => {
const container = document.getElementById("commentsContainer");

const div = document.createElement("div");
div.className = "comment-item";

div.innerHTML = `
<strong>${data.userName}</strong><br>
${data.comment}<br>
<small>${data.dateText}</small>
`;

container.prepend(div);

/* UPDATE COUNT */
const count = document.getElementById("commentCount");
count.textContent = parseInt(count.textContent) + 1;
});

/* MEDICAL MARKED */
socket.on("medicalMarked", (data) => {

let feed = document.getElementById("medicalFeed");

if (!feed) {
  const div = document.createElement("div");
  div.id = "medicalFeed";
  div.className = "medical-feed-card";

  div.innerHTML = `
    <div class="feed-header">
      <div class="feed-avatar">
        <img src="https://ui-avatars.com/api/?name=${data.userName || 'System'}&background=c62828&color=fff">
      </div>
      <div class="feed-meta">
        <strong>${data.userName || 'System Update'}</strong>
        <div class="feed-time">Just now</div>
      </div>
    </div>

    <div class="feed-body">
      <div class="feed-title">🚨 Medical Attention Required</div>
      <div class="feed-content">
        <strong>Type:</strong> ${data.type}<br>
        <strong>Details:</strong> ${data.details}
      </div>
    </div>

    <div class="feed-actions">
      💬 <span id="commentCount">0</span>
    </div>

    <div id="commentSection" class="comment-section">
      <div id="commentsContainer"></div>
    </div>
  `;

  document.querySelector(".container").prepend(div);
}

});

/* MEDICAL UNMARKED */
socket.on("medicalUnmarked", () => {
const feed = document.getElementById("medicalFeed");
if (feed) feed.remove();
});

</script>
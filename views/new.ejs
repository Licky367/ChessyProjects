<div class="container mt-4">

  <div class="card shadow-sm p-4">
    <h2 class="mb-4">Add New Dairy Record</h2>

    <form action="/dairy/new" method="POST" enctype="multipart/form-data">

      <!-- ========================= -->
      <!-- NAME -->
      <!-- ========================= -->
      <div class="mb-3">
        <label class="form-label">Name</label>
        <input
          type="text"
          name="name"
          class="form-control"
          placeholder="Enter name"
          required
        >
      </div>

      <!-- ========================= -->
      <!-- PROFILE IMAGE UPLOAD -->
      <!-- ========================= -->
      <div class="mb-3">
        <label class="form-label">Profile Image</label>
        <input
          type="file"
          name="profileImage"
          class="form-control"
          accept="image/*"
        >
      </div>

      <!-- ========================= -->
      <!-- DOB -->
      <!-- ========================= -->
      <div class="mb-3">
        <label class="form-label">Date of Birth</label>
        <input
          type="date"
          name="dob"
          class="form-control"
        >
      </div>

      <!-- ========================= -->
      <!-- CODE -->
      <!-- ========================= -->
      <div class="mb-3">
        <label class="form-label">Code</label>
        <input
          type="number"
          name="code"
          class="form-control"
          placeholder="Enter unique code"
          required
        >
      </div>

      <!-- ========================= -->
      <!-- MASS -->
      <!-- ========================= -->
      <div class="mb-3">
        <label class="form-label">Mass (Kg)</label>
        <input
          type="number"
          name="mass"
          class="form-control"
          placeholder="Enter mass"
          min="0"
          step="0.1"
          required
        >
      </div>

      <button type="submit" class="btn btn-success w-100">
        Save Record
      </button>

    </form>

  </div>

</div>
<div class="container mt-4">

  <div class="card shadow-sm p-4">
    <h2 class="mb-4">Add New Dairy Record</h2>

    <!-- ========================= -->
    <!-- IMAGE PREVIEW -->
    <!-- ========================= -->
    <div class="text-center mb-3">

      <img
        id="previewImage"
        src="/images/avatar.png"
        alt="Profile Preview"
        style="width:120px;height:120px;object-fit:cover;border-radius:50%;border:2px solid #ccc;"
      >

      <div class="mt-2">
        <input
          type="file"
          name="profileImage"
          id="profileImageInput"
          class="form-control"
          accept="image/*"

    </div>

    <form action="/dairy/new" method="POST" enctype="multipart/form-data">

      <!-- ========================= -->
      <!-- NAME -->
      <!-- ========================= -->
      <div class="mb-3">
        <label class="form-label">Name</label>
        <input
          type="text"
          name="name"
          class="form-control"
          placeholder="Enter name"
          required
        >
      </div>

      <!-- ========================= -->
      <!-- DOB -->
      <!-- ========================= -->
      <div class="mb-3">
        <label class="form-label">Date of Birth</label>
        <input
          type="date"
          name="dob"
          class="form-control"
        >
        <small class="text-muted">
          Ignored if code is negative.
        </small>
      </div>

      <!-- ========================= -->
      <!-- CODE -->
      <!-- ========================= -->
      <div class="mb-3">
        <label class="form-label">Code</label>
        <input
          type="number"
          name="code"
          id="codeInput"
          class="form-control"
          placeholder="Enter unique code"
          required
        >

        <small id="codeHint" class="text-muted d-block mt-1">
          Enter a code to see classification.
        </small>
      </div>

      <!-- ========================= -->
      <!-- MASS -->
      <!-- ========================= -->
      <div class="mb-3">
        <label class="form-label">Mass (Kg)</label>
        <input
          type="number"
          name="mass"
          class="form-control"
          placeholder="Enter mass"
          min="0"
          step="0.1"
          required
        >
      </div>

      <button type="submit" class="btn btn-success w-100">
        Save Record
      </button>

    </form>

  </div>

</div>

<!-- ========================= -->
<!-- JAVASCRIPT -->
<!-- ========================= -->
<script>
  // =========================
  // IMAGE PREVIEW LOGIC
  // =========================
  const imageInput = document.getElementById("profileImageInput");
  const previewImage = document.getElementById("previewImage");

  imageInput.addEventListener("change", function () {
    const file = this.files[0];

    if (file) {
      const reader = new FileReader();

      reader.onload = function (e) {
        previewImage.src = e.target.result;
      };

      reader.readAsDataURL(file);
    } else {
      previewImage.src = "/images/avatar.png";
    }
  });


  // =========================
  // CODE CLASSIFICATION LOGIC
  // =========================
  const codeInput = document.getElementById("codeInput");
  const codeHint = document.getElementById("codeHint");

  codeInput.addEventListener("input", function () {
    const value = parseInt(this.value);

    if (isNaN(value)) {
      codeHint.textContent = "Enter a valid number.";
      return;
    }

    if (value < 0) {
      codeHint.textContent = "⚠ Non-animal record (DOB will be ignored).";
      codeHint.style.color = "red";
    } 
    else if (value % 2 === 0) {
      codeHint.textContent = "♀ Female animal (even code).";
      codeHint.style.color = "green";
    } 
    else {
      codeHint.textContent = "♂ Male animal (odd code).";
      codeHint.style.color = "blue";
    }
  });
</script>
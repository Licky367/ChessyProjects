<div class="accounts-container">

  <h2 class="page-title">All Users</h2>

  <div class="users-grid">
    <% users.forEach(user => { %>
      <a href="/accounts/<%= user._id %>" class="user-card">

        <div class="avatar">
          <img src="<%= user.profileImage || '/images/default.png' %>" alt="">
        </div>

        <div class="info">
          <h3><%= user.name %></h3>
          <p><%= user.email %></p>
          <span class="role"><%= user.role %></span>
        </div>

      </a>
    <% }) %>
  </div>

</div>

<style>
.accounts-container{
  padding:20px;
  color:#fff;
}

.page-title{
  margin-bottom:20px;
  color:#9be7c4;
}

.users-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(250px,1fr));
  gap:20px;
}

.user-card{
  display:flex;
  gap:15px;
  background:#0f2f25;
  padding:15px;
  border-radius:12px;
  text-decoration:none;
  color:#fff;
  transition:.2s;
}

.user-card:hover{
  background:#164c3a;
}

.avatar img{
  width:55px;
  height:55px;
  border-radius:50%;
  object-fit:cover;
}

.info h3{
  margin:0;
}

.info p{
  font-size:13px;
  opacity:.7;
}

.role{
  display:inline-block;
  margin-top:5px;
  font-size:12px;
  background:#1f6f54;
  padding:3px 8px;
  border-radius:6px;
}
</style>
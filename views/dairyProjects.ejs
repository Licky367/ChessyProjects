<!-- views/dairyProjects.ejs -->

<div class="container">

  <h2 style="margin-bottom:15px;color:#0b5d1e;">Dairy Profiles</h2>

  <ul class="wa-list">

    <% if (dairies && dairies.length > 0) { %>

      <% dairies.forEach(dairy => { %>

        <% if (dairy.code > 0) { %>

          <li class="wa-item">
            <a href="/dairy/<%= dairy._id %>" class="wa-link">

              <!-- AVATAR -->
              <div class="wa-avatar-box">
                <% if (dairy.profileImage && dairy.profileImage.trim() !== "") { %>
                  <img src="/uploads/<%= dairy.profileImage %>" class="wa-avatar">
                <% } else { %>
                  <img src="https://ui-avatars.com/api/?name=<%= dairy.name %>&background=0b5d1e&color=fff" class="wa-avatar">
                <% } %>
              </div>

              <!-- DETAILS -->
              <div class="wa-details">

                <div class="wa-name">
                  <%= dairy.name %>

                  <!-- MEDICAL BADGE -->
                  <% if (dairy.medicalAttention && dairy.medicalAttention.isMarked) { %>
                    <span style="
                      background:#c62828;
                      color:#fff;
                      font-size:11px;
                      padding:2px 6px;
                      border-radius:6px;
                      margin-left:6px;
                    ">
                      Medical Attention
                    </span>
                  <% } %>
                </div>

                <div class="wa-subtext">Code: <%= dairy.code %></div>

                <!-- MEDICAL DETAILS -->
                <% if (dairy.medicalAttention && dairy.medicalAttention.isMarked) { %>
                  <div class="wa-subtext" style="color:#b71c1c; margin-top:4px;">
                    <strong>Type:</strong> <%= dairy.medicalAttention.type %><br>
                    <strong>Details:</strong> <%= dairy.medicalAttention.details %>
                  </div>
                <% } %>

                <!-- ACTIONS -->
                <div style="margin-top:8px; display:flex; gap:8px; flex-wrap:wrap;">

                  <!-- MARK (dairyWorker only, if not already marked) -->
                  <% if (
                        user &&
                        user.role === 'dairyWorker' &&
                        (!dairy.medicalAttention || !dairy.medicalAttention.isMarked)
                      ) { %>

                    <form action="/dairy/<%= dairy._id %>/medical-mark" method="POST"
                          style="display:flex;flex-direction:column;gap:5px;">

                      <input type="text"
                             name="type"
                             placeholder="Medical type (e.g. Mastitis)"
                             required
                             style="padding:5px; border:1px solid #ccc; border-radius:4px;">

                      <input type="text"
                             name="details"
                             placeholder="Details..."
                             required
                             style="padding:5px; border:1px solid #ccc; border-radius:4px;">

                      <button type="submit"
                              style="background:#c62828;color:#fff;border:none;padding:6px;border-radius:4px;">
                        Mark Medical
                      </button>
                    </form>

                  <% } %>

                  <!-- UNMARK (admin only) -->
                  <% if (
                        user &&
                        user.role === 'admin' &&
                        dairy.medicalAttention &&
                        dairy.medicalAttention.isMarked
                      ) { %>

                    <form action="/dairy/<%= dairy._id %>/medical-unmark" method="POST">
                      <button type="submit"
                              style="background:#0b5d1e;color:#fff;border:none;padding:6px;border-radius:4px;">
                        Unmark Medical
                      </button>
                    </form>

                  <% } %>

                </div>

              </div>

            </a>
          </li>

        <% } %>

      <% }) %>

    <% } else { %>
      <p>No dairy profiles found.</p>
    <% } %>

  </ul>

</div>


<style>
/* ========================= */
/* WHATSAPP STYLE LIST */
/* ========================= */

.wa-list{
  list-style:none;
  padding:0;
  margin:0;
  background:#fff;
  border-radius:14px;
  box-shadow:0 6px 18px rgba(0,0,0,.08);
  overflow:hidden;
}

.wa-item{
  border-bottom:1px solid #eee;
}

.wa-item:last-child{
  border-bottom:none;
}

.wa-link{
  display:flex;
  align-items:center;
  gap:12px;
  padding:12px 14px;
  text-decoration:none;
  color:#222;
  transition:.2s ease;
}

.wa-link:hover{
  background:#f4f6f8;
}

.wa-avatar-box{
  flex:0 0 auto;
}

.wa-avatar{
  width:52px;
  height:52px;
  border-radius:50%;
  object-fit:cover;
  border:2px solid #0b5d1e;
}

.wa-details{
  flex:1;
  display:flex;
  flex-direction:column;
}

.wa-name{
  font-size:16px;
  font-weight:bold;
  color:#111;
}

.wa-subtext{
  font-size:13px;
  color:#666;
  margin-top:3px;
}
</style>
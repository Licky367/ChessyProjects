<% layout('layout', { title: 'Poultry Statistics' }) %>

<div class="container">

<h2>Poultry Statistics Dashboard</h2>

<!-- FILTER -->
<form method="GET" action="/poultry-stats">
  <input type="date" name="date" value="<%= date ? new Date(date).toISOString().split('T')[0] : '' %>">

  <select name="mode">
    <option value="eggs" <%= mode === 'eggs' ? 'selected' : '' %>>Eggs Collected</option>
    <option value="sales" <%= mode === 'sales' ? 'selected' : '' %>>Egg Sales Income</option>
  </select>

  <button type="submit">Filter</button>
</form>

<hr>

<!-- TABLE -->
<table border="1" width="100%" cellpadding="10">
  <thead>
    <tr>
      <th>Poultry Type</th>
      <th>Day Total</th>
      <th>Month Total</th>
      <th>Year Total</th>
      <th>Overall Total</th>
    </tr>
  </thead>

  <tbody>
    <% if (Array.isArray(data)) { %>
      <% data.forEach(row => { %>
        <tr>
          <td><%= row.poultryType %></td>
          <td><%= row.dayTotal %></td>
          <td><%= row.monthTotal %></td>
          <td><%= row.yearTotal %></td>
          <td><%= row.overall %></td>
        </tr>
      <% }) %>
    <% } else { %>
        <tr>
          <td colspan="5" style="text-align:center">
            Day: <%= data.dayTotal %> |
            Month: <%= data.monthTotal %> |
            Year: <%= data.yearTotal %> |
            Overall: <%= data.overall %>
          </td>
        </tr>
    <% } %>
  </tbody>
</table>

</div>
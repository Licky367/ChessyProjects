<h2>Poultry Analytics Dashboard</h2>

<form method="GET" action="/poultry-stats">
    <input type="date" name="date" value="<%= selectedDate || '' %>">

    <select name="type">
        <option value="eggs" <%= selectedType === "eggs" ? "selected" : "" %>>Eggs Collected</option>
        <option value="egg_sales" <%= selectedType === "egg_sales" ? "selected" : "" %>>Egg Sales Revenue</option>
        <option value="poultry_sales" <%= selectedType === "poultry_sales" ? "selected" : "" %>>Poultry Sales Revenue</option>
        <option value="total_revenue" <%= selectedType === "total_revenue" ? "selected" : "" %>>Total Revenue</option>
        <option value="profit" <%= selectedType === "profit" ? "selected" : "" %>>Profit</option>
    </select>

    <button>Filter</button>
</form>

<hr>

<table border="1" cellpadding="10">
    <thead>
        <tr>
            <th>Poultry Type</th>
            <th>Day Total</th>
            <th>Month Total</th>
            <th>Year Total</th>
        </tr>
    </thead>

    <tbody>
        <% rows.forEach(r => { %>
            <tr>
                <td><%= r.poultryType %></td>
                <td><%= r.day %></td>
                <td><%= r.month %></td>
                <td><%= r.year %></td>
            </tr>
        <% }) %>
    </tbody>

    <tfoot>
        <tr>
            <th>Total</th>
            <th><%= grandTotal.day %></th>
            <th><%= grandTotal.month %></th>
            <th><%= grandTotal.year %></th>
        </tr>
    </tfoot>
</table>
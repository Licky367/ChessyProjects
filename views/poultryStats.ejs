<h2>Poultry Analytics Dashboard</h2>

<form method="GET" action="/poultry-stats">
    <input type="date" name="date" value="<%= selectedDate || '' %>">

    <select name="type">
        <option value="eggs" <%= selectedType === "eggs" ? "selected" : "" %>>Eggs Collected</option>
        <option value="sales" <%= selectedType === "sales" ? "selected" : "" %>>Egg Sales Revenue</option>
    </select>

    <button>Filter</button>
</form>

<hr>

<table border="1" cellpadding="10">
    <thead>
        <tr>
            <th>Poultry Type</th>
            <th>Day Total</th>
            <th>Month Total</th>
            <th>Year Total</th>
        </tr>
    </thead>

    <tbody>
        <% rows.forEach(r => { %>
            <tr>
                <td><%= r.poultryType %></td>
                <td><%= r.day %></td>
                <td><%= r.month %></td>
                <td><%= r.year %></td>
            </tr>
        <% }) %>
    </tbody>

    <!-- TOTAL ROW -->
    <tfoot>
        <tr>
            <th>Total</th>
            <th>
                <%= rows.reduce((a, b) => a + b.day, 0) %>
            </th>
            <th>
                <%= rows.reduce((a, b) => a + b.month, 0) %>
            </th>
            <th>
                <%= rows.reduce((a, b) => a + b.year, 0) %>
            </th>
        </tr>
    </tfoot>
</table>
<!-- views/structures.ejs -->

<div class="container">

  <h2 style="margin-bottom:15px;color:#0b5d1e;">Dairy Structures</h2>

  <ul class="wa-list">

    <% if (dairies && dairies.length > 0) { %>

      <% dairies.forEach(dairy => { %>

        <% if (dairy.code < 0) { %>

          <li class="wa-item">

            <a href="/dairy/<%= dairy._id %>" class="wa-link">

              <div class="wa-avatar-box">

                <% if (dairy.profileImage && dairy.profileImage.trim() !== "") { %>
                  <img src="/uploads/<%= dairy.profileImage %>" class="wa-avatar">
                <% } else { %>
                  <img src="https://ui-avatars.com/api/?name=<%= dairy.name %>&background=0b5d1e&color=fff" class="wa-avatar">
                <% } %>

              </div>

              <div class="wa-details">

                <div class="wa-name"><%= dairy.name %></div>

                <div class="wa-subtext">Facility Code: <%= dairy.code %></div>

                <div class="wa-subtext">
                  Status:
                  <% if (dairy.needsMaintenance === true) { %>
                    <span style="color:#b00020;font-weight:bold;">Needs Repair/Maintenance</span>
                  <% } else { %>
                    <span style="color:#0b5d1e;font-weight:bold;">OK</span>
                  <% } %>
                </div>

              </div>

            </a>

            <!-- ACTIONS -->
            <div style="padding:10px 14px; display:flex; gap:10px; flex-wrap:wrap;">

              <!-- ========================= -->
              <!-- CASE 1: OK → MARK (TOGGLE FORM) -->
              <!-- ========================= -->
              <% if (dairy.needsMaintenance === false && user && (user.role === 'admin' || user.role === 'dairyWorker')) { %>

                <!-- BUTTON ONLY -->
                <button type="button"
                        onclick="toggleForm('<%= dairy._id %>')"
                        style="padding:6px 10px; background:#0b5d1e; color:#fff; border:none; border-radius:6px; cursor:pointer;">
                  Mark Maintenance
                </button>

                <!-- HIDDEN FORM -->
                <form id="form-<%= dairy._id %>"
                      action="/dairy/<%= dairy._id %>/maintenance/mark"
                      method="POST"
                      style="display:none; margin-top:10px; width:100%;">

                  <select name="type" required style="padding:6px; width:100%; margin-bottom:6px;">
                    <option value="">Select Type</option>
                    <option value="repair">Repair</option>
                    <option value="maintenance">Maintenance</option>
                    <option value="construction">Construction</option>
                  </select>

                  <textarea name="description"
                            placeholder="Describe issue..."
                            required
                            style="width:100%; padding:6px; margin-bottom:6px;"></textarea>

                  <button type="submit"
                          style="padding:6px 10px; background:#b00020; color:#fff; border:none; border-radius:6px;">
                    Submit
                  </button>

                </form>

              <% } %>

              <!-- ========================= -->
              <!-- CASE 2: NEEDS → ONLY UNMARK -->
              <!-- ========================= -->
              <% if (dairy.needsMaintenance === true && user && user.role === 'admin') { %>

                <form action="/dairy/<%= dairy._id %>/maintenance/clear" method="POST">

                  <button type="submit"
                          style="padding:6px 10px; background:#444; color:#fff; border:none; border-radius:6px; cursor:pointer;">
                    Unmark Maintenance
                  </button>

                </form>

              <% } %>

            </div>

          </li>

        <% } %>

      <% }) %>

    <% } else { %>

      <p>No dairy structures found.</p>

    <% } %>

  </ul>

</div>

<script>
function toggleForm(id){
  const form = document.getElementById("form-" + id);
  if (!form) return;

  if (form.style.display === "none" || form.style.display === "") {
    form.style.display = "block";
  } else {
    form.style.display = "none";
  }
}
</script>

<style>
.container{
  max-width:1000px;
  margin:auto;
}

.wa-list{
  list-style:none;
  padding:0;
  margin:0;
  background:#fff;
  border-radius:14px;
  box-shadow:0 6px 18px rgba(0,0,0,.08);
  overflow:hidden;
}

.wa-item{
  border-bottom:1px solid #eee;
}

.wa-item:last-child{
  border-bottom:none;
}

.wa-link{
  display:flex;
  align-items:center;
  gap:12px;
  padding:12px 14px;
  text-decoration:none;
  color:#222;
  transition:.2s ease;
}

.wa-link:hover{
  background:#f4f6f8;
}

.wa-avatar{
  width:52px;
  height:52px;
  border-radius:50%;
  object-fit:cover;
  border:2px solid #0b5d1e;
}

.wa-details{
  flex:1;
  display:flex;
  flex-direction:column;
}

.wa-name{
  font-size:16px;
  font-weight:bold;
  color:#111;
}

.wa-subtext{
  font-size:13px;
  color:#666;
  margin-top:3px;
}
</style>
  color: #333;
  transition: 0.2s ease;
  border-left: 5px solid #0b5d1e;
}

.card:hover {
  transform: translateY(-3px);
}

.card h3 {
  margin-bottom: 8px;
  color: #0b5d1e;
}

.card p {
  font-size: 14px;
  color: #555;
}
</style>


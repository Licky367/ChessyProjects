  <!-- HEADER -->
  <div class="header">
    <h2>Financial Dashboard</h2>
    <p>Select a report to view detailed analytics</p>
  </div>

  <!-- NAVIGATION CARDS -->
  <div class="grid">

    <a href="/financials/daily-customers" class="card">
      <h3>Daily Customers</h3>
      <p>View and filter customer sales by specific dates</p>
    </a>

    <a href="/financials/summary" class="card">
      <h3>Financial Summary</h3>
      <p>View profit, income, and expenses by month & year</p>
    </a>

    <a href="/financials/expenses" class="card">
      <h3>Monthly Expenses</h3>

<!DOCTYPE html>
<html lang="en">    
<head>    
<meta charset="UTF-8">    
<meta name="viewport" content="width=device-width, initial-scale=1.0">    
<title><%= title || "Projects" %></title>  

<style>    
*{margin:0;padding:0;box-sizing:border-box;font-family:Arial,sans-serif;}    
body{background:#f4f6f8;min-height:100vh;}    

/* HEADER */
.header{
position:fixed;
top:0;
left:0;
right:0;
height:70px;
background:#0b5d1e;
color:#fff;
display:flex;
align-items:center;
justify-content:space-between;
padding:0 15px;
z-index:1000;
}

/* LEFT HEADER */
.header-left{
display:flex;
align-items:center;
gap:12px;
}

/* MENU BUTTON */
.menu-btn{
font-size:26px;
cursor:pointer;
color:#0b5d1e;
background:#fff;
width:40px;
height:40px;
display:flex;
align-items:center;
justify-content:center;
border-radius:8px;
}

/* TITLE */
.header-title{
font-size:20px;
font-weight:bold;
}

/* PROFILE */
.profile-box{position:relative;}

.profile-trigger{
display:flex;
flex-direction:column;
align-items:center;
cursor:pointer;
}

.profile-avatar{
width:36px;
height:36px;
border-radius:50%;
border:2px solid #fff;
}

.profile-name{
font-size:11px;
color:#fff;
max-width:70px;
overflow:hidden;
text-overflow:ellipsis;
white-space:nowrap;
}

.dropdown{
position:absolute;
right:0;
top:55px;
width:180px;
background:#fff;
border-radius:10px;
box-shadow:0 10px 25px rgba(0,0,0,.1);
display:none;
}

.dropdown a{
display:block;
padding:12px;
text-decoration:none;
color:#333;
border-bottom:1px solid #eee;
}

.profile-box.active .dropdown{display:block;}

/* SIDEBAR */
.sidebar{
position:fixed;
top:70px;
left:-260px;
width:240px;
height:calc(100% - 70px - 50px);
background:#0b5d1e;
padding:20px;
transition:.3s ease;
overflow-y:auto;
}

.sidebar.active{left:0;}

.sidebar h2{
color:#fff;
margin-top:15px;
font-size:16px;
cursor:pointer;
}

.sidebar .submenu{
display:none;
margin-top:8px;
}

.sidebar .submenu a{
display:block;
color:#fff;
text-decoration:none;
padding:10px;
font-size:14px;
}

.sidebar .submenu a:hover{
background:rgba(255,255,255,.15);
}

/* OVERLAY */
.overlay{
position:fixed;
top:0;
left:0;
right:0;
bottom:0;
background:rgba(0,0,0,.3);
display:none;
}
.overlay.active{display:block;}

/* MAIN */
.main{
padding:90px 20px 80px;
}

/* FOOTER */
.footer{
position:fixed;
bottom:0;
left:0;
right:0;
height:50px;
background:#0b5d1e;
color:#fff;
display:flex;
align-items:center;
justify-content:center;
font-size:13px;
}
</style>  
</head>  

<body>  

<%
const authPages = ["/login","/signup","/forgot-password","/reset-password"];
const isAuthPage = authPages.includes(req.path);

let headerTitle = "Corevester";

if(user){
  if(user.role === "admin") headerTitle = "My Projects";
  if(user.role === "dairyWorker") headerTitle = "Dairy Project";
  if(user.role === "poultryWorker") headerTitle = "Poultry Project";
}
%>

<% if (!isAuthPage) { %>

<!-- HEADER -->
<div class="header">

  <div class="header-left">
    <div class="menu-btn" onclick="openSidebar()">&#9776;</div>
    <div class="header-title"><%= headerTitle %></div>
  </div>

  <!-- PROFILE -->
  <div class="profile-box" id="profileBox">
    <div class="profile-trigger" onclick="toggleProfile(event)">
      <% if (user && user.profileImage) { %>
        <img src="/uploads/<%= user.profileImage %>" class="profile-avatar">
      <% } else { %>
        <img src="https://ui-avatars.com/api/?name=<%= user ? user.name : 'User' %>" class="profile-avatar">
      <% } %>
      <div class="profile-name"><%= user ? user.name : "Profile" %></div>
    </div>

    <div class="dropdown">
      <% if(user){ %>
        <a href="/profile">👤 My Account</a>
        <a href="/logout">🚪 Logout</a>
      <% } else { %>
        <a href="/login">Login</a>
        <a href="/signup">Sign Up</a>
      <% } %>
    </div>
  </div>

</div>

<!-- SIDEBAR -->
<div class="sidebar" id="sidebar">

  <% if(user && user.role === "admin"){ %>

    <h2 onclick="toggleMenu('dairyMenu')">DAIRY PROJECTS</h2>
    <div class="submenu" id="dairyMenu">
      <a href="/dairy">Home</a>
      <a href="/dairyProjects">View Dairy Projects</a>
      <a href="/addDairyProject">Add Project</a>
    </div>

    <h2 onclick="toggleMenu('poultryMenu')">POULTRY PROJECTS</h2>
    <div class="submenu" id="poultryMenu">
      <a href="/poultry">Home</a>
      <a href="/addPoultryProject">Add Project</a>
    </div>

  <% } else if(user && user.role === "dairyWorker"){ %>

    <a href="/dairy">Home</a>
    <a href="/dairyProjects">View Projects</a>

  <% } else if(user && user.role === "poultryWorker"){ %>

    <a href="/poultry">Home</a>
    <a href="/poultryProjects">View Projects</a>

  <% } %>

</div>

<div class="overlay" id="overlay" onclick="closeSidebar()"></div>

<% } %>

<!-- MAIN -->
<div class="main <%= isAuthPage ? 'auth' : '' %>">
  <%- body %>
</div>

<% if (!isAuthPage) { %>

<!-- FOOTER -->
<div class="footer">
  © <%= new Date().getFullYear() %> Dr. Chessy Edwin
</div>

<script>
const sidebar = document.getElementById("sidebar");
const overlay = document.getElementById("overlay");
const profileBox = document.getElementById("profileBox");

function openSidebar(){
  sidebar.classList.add("active");
  overlay.classList.add("active");
}

function closeSidebar(){
  sidebar.classList.remove("active");
  overlay.classList.remove("active");
}

function toggleProfile(e){
  e.stopPropagation();
  profileBox.classList.toggle("active");
}

function toggleMenu(id){
  const el = document.getElementById(id);
  el.style.display = el.style.display === "block" ? "none" : "block";
}

document.addEventListener("click",()=>{
  profileBox.classList.remove("active");
});
</script>

<% } %>

</body>    
</html>
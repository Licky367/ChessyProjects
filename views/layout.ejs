<!DOCTYPE html>
<html lang="en">    
<head>    
<meta charset="UTF-8">    
<meta name="viewport" content="width=device-width, initial-scale=1.0">    
<title><%= title || "Projects" %></title>  

<style>    
*{margin:0;padding:0;box-sizing:border-box;font-family:Arial,sans-serif;}    
body{background:#f4f6f8;min-height:100vh;}    

/* HEADER */
.header{
position:fixed;
top:0;
left:0;
right:0;
height:70px;
background:#0b5d1e;
color:#fff;
display:flex;
align-items:center;
justify-content:space-between;
padding:0 15px;
z-index:1000;
}

.header-left{
display:flex;
align-items:center;
gap:12px;
}

.menu-btn{
font-size:26px;
cursor:pointer;
color:#0b5d1e;
background:#fff;
width:40px;
height:40px;
display:flex;
align-items:center;
justify-content:center;
border-radius:8px;
}

.header-title{
font-size:20px;
font-weight:bold;
}

/* PROFILE */
.profile-box{position:relative;}

.profile-trigger{
display:flex;
flex-direction:column;
align-items:center;
cursor:pointer;
}

.profile-avatar{
width:36px;
height:36px;
border-radius:50%;
border:2px solid #fff;
}

.profile-name{
font-size:11px;
color:#fff;
max-width:70px;
overflow:hidden;
text-overflow:ellipsis;
white-space:nowrap;
}

.dropdown-profile{
position:absolute;
right:0;
top:55px;
width:180px;
background:#fff;
border-radius:10px;
box-shadow:0 10px 25px rgba(0,0,0,.1);
display:none;
}

.dropdown-profile a{
display:block;
padding:12px;
text-decoration:none;
color:#333;
border-bottom:1px solid #eee;
}

.profile-box.active .dropdown-profile{display:block;}

/* SIDEBAR */
.sidebar{
position:fixed;
top:70px;
left:-260px;
width:240px;
height:calc(100% - 70px - 50px);
background:#0b5d1e;
padding:15px;
transition:.3s ease;
overflow-y:auto;
}

.sidebar.active{left:0;}

.sidebar a{
display:block;
color:#fff;
text-decoration:none;
padding:10px;
border-radius:6px;
margin-bottom:5px;
font-size:14px;
}

.sidebar a:hover{
background:rgba(255,255,255,.15);
}

/* DROPDOWN */
.dropdown-section{
margin-top:10px;
}

.dropdown-header{
color:#fff;
padding:10px;
cursor:pointer;
display:flex;
justify-content:space-between;
align-items:center;
border-radius:6px;
}

.dropdown-header:hover{
background:rgba(255,255,255,.15);
}

.dropdown-content{
display:none;
padding-left:10px;
}

.dropdown-section.active .dropdown-content{
display:block;
}

.dropdown-content a{
font-size:13px;
padding-left:15px;
}

/* OVERLAY */
.overlay{
position:fixed;
top:0;
left:0;
right:0;
bottom:0;
background:rgba(0,0,0,.3);
display:none;
}
.overlay.active{display:block;}

/* MAIN */
.main{
padding:90px 20px 80px;
}

/* FOOTER */
.footer{
position:fixed;
bottom:0;
left:0;
right:0;
height:50px;
background:#0b5d1e;
color:#fff;
display:flex;
align-items:center;
justify-content:center;
font-size:13px;
}
</style>  
</head>  

<body>  

<%
const authPages = ["/login","/signup","/forgot-password","/reset-password"];
const isAuthPage = authPages.includes(req.path);

let headerTitle = "Corevester";

if(user){
  if(user.role === "admin") headerTitle = "My Projects";
  if(user.role === "dairyWorker") headerTitle = "Dairy Project";
  if(user.role === "poultryWorker") headerTitle = "Poultry Project";
}
%>

<% if (!isAuthPage) { %>

<div class="header">

  <div class="header-left">
    <div class="menu-btn" onclick="openSidebar()">&#9776;</div>
    <div class="header-title"><%= headerTitle %></div>
  </div>

  <div class="profile-box" id="profileBox">
    <div class="profile-trigger" onclick="toggleProfile(event)">
      <% if (user && user.profileImage) { %>
        <img src="/uploads/<%= user.profileImage %>" class="profile-avatar">
      <% } else { %>
        <img src="https://ui-avatars.com/api/?name=<%= user ? user.name : 'User' %>" class="profile-avatar">
      <% } %>
      <div class="profile-name"><%= user ? user.name : "Profile" %></div>
    </div>

    <div class="dropdown-profile">
      <% if(user){ %>
        <a href="/profile">👤 My Account</a>
        <a href="/logout">🚪 Logout</a>
      <% } %>
    </div>
  </div>

</div>

<!-- SIDEBAR -->
<div class="sidebar" id="sidebar">

  <% if(user && user.role === "admin"){ %>

    <a href="/">🏠 Home</a>
    <a href="/create-staff">👥 Add Staff</a>

    <!-- DAIRY DROPDOWN -->
    <div class="dropdown-section">
      <div class="dropdown-header" onclick="toggleDropdown(this)">
        🐄 Dairy Projects ⌄
      </div>
      <div class="dropdown-content">
        <a href="/dairy/new">➕ Add Project</a>
        <a href="/dairy/projects">📁 View Dairy Projects</a>
        <a href="/structures">🏗️ View Dairy Facilities</a>
        <a href="/milk">🥛 Production</a>
        <a href="/sales">💰 Sales</a>
        <a href="/milk/stats">📊 Statistics</a>
        <a href="/financials">📈 Financials</a>
      </div>
    </div>

    <!-- POULTRY DROPDOWN -->
    <div class="dropdown-section">
      <div class="dropdown-header" onclick="toggleDropdown(this)">
        🐔 Poultry Projects ⌄
      </div>
      <div class="dropdown-content">
        <a href="/poultry/add">➕ Add Project</a>
        <a href="/poultry/projects">📁 View Poultry Projects</a>
      </div>
    </div>

  <% } else if(user && user.role === "dairyWorker"){ %>

    <a href="/">🏠 Home</a>
    <a href="/dairy/projects">🐄 View Dairy Cattle</a>
    <a href="/structures">🏗️ View Dairy Facilities</a>
    <a href="/milk">🥛 Record Production</a>
    <a href="/sales">💰 Sales</a>

  <% } %>

</div>

<div class="overlay" id="overlay" onclick="closeSidebar()"></div>

<% } %>

<div class="main">
  <%- body %>
</div>

<% if (!isAuthPage) { %>

<div class="footer">
  © <%= new Date().getFullYear() %> Dr. Chessy Edwin
</div>

<script>
const sidebar = document.getElementById("sidebar");
const overlay = document.getElementById("overlay");

function openSidebar(){
  sidebar.classList.add("active");
  overlay.classList.add("active");
}

function closeSidebar(){
  sidebar.classList.remove("active");
  overlay.classList.remove("active");
}

function toggleDropdown(el){
  const parent = el.parentElement;

  document.querySelectorAll(".dropdown-section").forEach(sec=>{
    if(sec !== parent) sec.classList.remove("active");
  });

  parent.classList.toggle("active");
}
</script>

<% } %>

</body>    
</html>
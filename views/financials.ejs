<style>
.page {
  max-width: 1200px;
  margin: auto;
}

/* =========================
   CARDS
========================= */
.card {
  background: #fff;
  padding: 22px;
  border-radius: 14px;
  box-shadow: 0 8px 20px rgba(0,0,0,.05);
  margin-bottom: 20px;
}

/* =========================
   GREEN HEADING STYLE
========================= */
.section-title {
  font-size: 18px;
  font-weight: 600;
  margin-bottom: 15px;
  padding-left: 12px;
  border-left: 5px solid #0b5d1e;
  color: #0b5d1e;
}

/* =========================
   FILTER BAR
========================= */
.filters {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-bottom: 15px;
}

input, select {
  padding: 8px;
  border-radius: 8px;
  border: 1px solid #ddd;
}

button {
  background: #0b5d1e;
  color: white;
  padding: 9px 14px;
  border: none;
  border-radius: 8px;
  cursor: pointer;
}

/* =========================
   SUMMARY BOXES
========================= */
.summary {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 10px;
}

.box {
  background: #f8f9fa;
  padding: 15px;
  border-radius: 10px;
}

.box h3 {
  color: #0b5d1e;
  margin-bottom: 5px;
}

/* =========================
   TABLES
========================= */
table {
  width: 100%;
  border-collapse: collapse;
  margin-top: 10px;
}

th, td {
  padding: 10px;
  border-bottom: 1px solid #eee;
  text-align: left;
}

th {
  background: #f8f9fa;
}

/* =========================
   TOTAL BAR
========================= */
.total {
  margin-top: 15px;
  padding: 12px;
  background: #e9f7ef;
  border-left: 5px solid #0b5d1e;
  font-weight: bold;
}
</style>


<div class="page">

  <!-- =========================
       FILTER SECTION
  ========================= -->
  <div class="card">

    <div class="section-title">Financial Filters</div>

    <form class="filters" method="GET" action="/financials">

      <input type="date" name="day" value="<%= day || '' %>">

      <input type="month" name="month" value="<%= month || '' %>">

      <input type="number" name="year" placeholder="Year" value="<%= year || '' %>">

      <select name="type">
        <option value="daily" <%= type === 'daily' ? 'selected' : '' %>>Daily</option>
        <option value="monthly" <%= type === 'monthly' ? 'selected' : '' %>>Monthly</option>
        <option value="yearly" <%= type === 'yearly' ? 'selected' : '' %>>Yearly</option>
      </select>

      <button>Generate</button>

    </form>

  </div>


  <!-- =========================
       SUMMARY
  ========================= -->
  <div class="card">

    <div class="section-title">Financial Summary</div>

    <div class="summary">

      <div class="box">
        <h3>Milk Income</h3>
        <p>KES <%= financial?.milkCash || 0 %></p>
      </div>

      <div class="box">
        <h3>Maintenance</h3>
        <p>KES <%= financial?.maintenanceCost || 0 %></p>
      </div>

      <div class="box">
        <h3>Medical</h3>
        <p>KES <%= financial?.medicalCost || 0 %></p>
      </div>

      <div class="box">
        <h3>Total Expenses</h3>
        <p>KES <%= financial?.totalExpenses || 0 %></p>
      </div>

      <div class="box">
        <h3>Profit</h3>
        <p>KES <%= financial?.profit || 0 %</p>
      </div>

    </div>

  </div>


  <!-- =========================
       DAILY SALES (CUSTOMER)
  ========================= -->
  <div class="card">

    <div class="section-title">Daily Customer Sales</div>

    <% if (sales && sales.length > 0) { %>

      <table>
        <thead>
          <tr>
            <th>Customer</th>
            <th>Liters</th>
            <th>Cash</th>
          </tr>
        </thead>

        <tbody>
          <% sales.forEach(s => { %>
            <tr>
              <td><%= s.customerName %></td>
              <td><%= s.liters %></td>
              <td>KES <%= s.cash %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>

      <div class="total">
        Total Sales Cash: KES <%= totalSalesCash || 0 %>
      </div>

    <% } else { %>
      <p>No sales records found.</p>
    <% } %>

  </div>


  <!-- =========================
       EXPENSES
  ========================= -->
  <div class="card">

    <div class="section-title">Monthly Expenses</div>

    <% if (expenses && expenses.length > 0) { %>

      <table>
        <thead>
          <tr>
            <th>Type</th>
            <th>Description</th>
            <th>Charges</th>
          </tr>
        </thead>

        <tbody>
          <% expenses.forEach(e => { %>
            <tr>
              <td><%= e.type %></td>
              <td>
                <%= e.type === 'maintenance'
                  ? e.maintenance?.description
                  : e.medical?.details %>
              </td>
              <td>KES <%= e.charges || 0 %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>

      <div class="total">
        Total Expenses: KES <%= totalExpenses || 0 %>
      </div>

    <% } else { %>
      <p>No expenses found.</p>
    <% } %>

  </div>

</div>
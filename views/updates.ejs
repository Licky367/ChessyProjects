<!-- views/update.ejs -->

<style>
.profile-wrap{
display:flex;
align-items:flex-start;
gap:18px;
flex-wrap:wrap;
}

.profile-left{
flex:0 0 auto;
}

.profile-right{
flex:1;
min-width:250px;
}

.profile-thumb{
width:72px;
height:72px;
border-radius:50%;
object-fit:cover;
cursor:pointer;
border:3px solid #fff;
box-shadow:0 4px 14px rgba(0,0,0,.15);
}

.profile-thumb:hover{
transform:scale(1.03);
transition:.2s;
}

.fb-sheet{
position:fixed;
left:0;
right:0;
bottom:-400px;
background:#fff;
border-radius:18px 18px 0 0;
box-shadow:0 -8px 30px rgba(0,0,0,.18);
z-index:3000;
transition:.25s ease;
padding:15px;
}

.fb-sheet.show{
bottom:0;
}

.fb-sheet button,
.fb-sheet a{
display:block;
width:100%;
padding:14px;
margin-bottom:8px;
border:none;
border-radius:10px;
background:#f4f4f4;
text-align:left;
text-decoration:none;
color:#222;
font-weight:600;
cursor:pointer;
}

.gallery-box{
position:relative;
background:#111;
text-align:center;
}

.gallery-img{
width:100%;
max-height:78vh;
object-fit:contain;
}

.gallery-nav{
position:absolute;
top:50%;
transform:translateY(-50%);
background:rgba(255,255,255,.85);
border:none;
width:42px;
height:42px;
border-radius:50%;
font-size:22px;
cursor:pointer;
}

.gallery-prev{left:10px;}
.gallery-next{right:10px;}

.comment-item{
border-bottom:1px solid #eee;
padding:10px 0;
}

.comment-box{
display:flex;
gap:10px;
margin-top:10px;
}

.comment-box textarea{
flex:1;
resize:none;
}

.editable{
cursor:pointer;
border-bottom:1px dashed #999;
}
</style>

<div class="container mt-4">

<div class="card shadow-sm border-0 p-4">

<div class="profile-wrap">

<!-- LEFT -->
<div class="profile-left">

<% if (dairy.profileImage) { %>
<img
src="/uploads/<%= dairy.profileImage %>"
alt="<%= dairy.name %>"
id="profilePreview"
class="profile-thumb"
>
<% } else { %>
<img
src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(dairy.name) %>&background=198754&color=fff&size=200"
alt="<%= dairy.name %>"
id="profilePreview"
class="profile-thumb"
>
<% } %>

</div>

<!-- RIGHT -->
<div class="profile-right">

<h3 class="mb-2">
<% if (user && user.role === 'admin') { %>
<span
class="editable"
data-field="name"
data-value="<%= dairy.name %>"
>
<%= dairy.name %>
</span>
<% } else { %>
<%= dairy.name %>
<% } %>
</h3>

<p class="mb-2">
<strong>Code:</strong>

<% if (user && user.role === 'admin') { %>
<span
class="editable"
data-field="code"
data-value="<%= dairy.code %>"
>
<%= dairy.code %>
</span>
<% } else { %>
<%= dairy.code %>
<% } %>
</p>

<p class="mb-2"><strong>Gender:</strong> <%= dairy.gender %></p>
<p class="mb-2"><strong>Age:</strong> <span id="ageText"></span></p>

<p class="mb-2">
<strong>Mass:</strong>

<% if (user && user.role === 'admin') { %>
<span
class="editable"
data-field="mass"
data-value="<%= dairy.mass || 0 %>"
>
<%= dairy.mass || 0 %>
</span>
<% } else { %>
<%= dairy.mass || 0 %>
<% } %>

Kgs
</p>

<% if (dairy.gender === 'Female') { %>
<p class="mb-2">

<strong>Status:</strong>

<% if (user && user.role === 'admin') { %>

<label>
<input
type="checkbox"
id="milkingToggle"
<%= dairy.isMilking ? 'checked' : '' %>
>

<span
id="milkBadge"
class="badge <%= dairy.isMilking ? 'bg-success' : 'bg-secondary' %>"
>
<%= dairy.isMilking ? 'Being Milked' : 'Not Milked' %>
</span>
</label>

<% } else { %>

<span
class="badge <%= dairy.isMilking ? 'bg-success' : 'bg-secondary' %>"
>
<%= dairy.isMilking ? 'Being Milked' : 'Not Milked' %>
</span>

<% } %>

</p>
<% } %>

<% if (user && user.role === 'admin') { %>
<hr>

<form
action="/dairy/<%= dairy._id %>?_method=DELETE"
method="POST"
onsubmit="return confirm('Delete this profile permanently?')"
>
<button class="btn btn-danger btn-sm">
Delete Profile
</button>
</form>
<% } %>

</div>
</div>
</div>
</div>

<!-- ACTION SHEET -->
<div class="fb-sheet" id="imageSheet">

<button onclick="openGallery()">👁 View Photo</button>

<% if (user && user.role === 'admin') { %>
<button onclick="document.getElementById('imageInput').click()">
📷 Change Photo
</button>

<form
id="deleteImageForm"
action="/dairy/<%= dairy._id %>/image?_method=DELETE"
method="POST"
>
<button type="submit">🗑 Delete Photo</button>
</form>
<% } %>

<button onclick="closeSheet()">Cancel</button>

</div>

<!-- VIEWER -->
<div
class="modal fade"
id="viewImageModal"
tabindex="-1"
>

<div class="modal-dialog modal-dialog-centered modal-xl">
<div class="modal-content border-0">

<div class="gallery-box">

<button
class="gallery-nav gallery-prev"
onclick="prevImage()"
>
‹
</button>

<img
id="galleryImage"
class="gallery-img"
src=""
>

<button
class="gallery-nav gallery-next"
onclick="nextImage()"
>
›
</button>

<div class="p-3 bg-white text-start">

<button
class="btn btn-sm btn-outline-dark"
data-bs-toggle="modal"
data-bs-target="#commentsModal"
>
💬 Comments
</button>

</div>

</div>
</div>
</div>
</div>

<!-- COMMENTS -->
<div class="modal fade" id="commentsModal" tabindex="-1">
<div class="modal-dialog">
<div class="modal-content">

<div class="modal-header">
<h5 class="modal-title">Comments</h5>
<button class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body">

<% if (updates && updates.length) { %>

<% updates.forEach(item => { %>
<div class="comment-item">
<strong><%= item.user?.name || 'User' %></strong><br>
<%= item.comment %><br>
<small class="text-muted">
<%= item.createdAt.toDateString() %>
</small>
</div>
<% }) %>

<% } else { %>
<p class="text-muted">No comments yet.</p>
<% } %>

<% if (user) { %>

<form
action="/dairy/<%= dairy._id %>/comment"
method="POST"
class="comment-box"
>

<textarea
name="comment"
rows="2"
class="form-control"
placeholder="Write comment..."
required
></textarea>

<button class="btn btn-primary">
Post
</button>

</form>

<% } %>

</div>
</div>
</div>
</div>

<!-- CHANGE IMAGE -->
<form
id="uploadForm"
action="/dairy/<%= dairy._id %>/image?_method=PUT"
method="POST"
enctype="multipart/form-data"
style="display:none;"
>
<input
type="file"
name="profileImage"
id="imageInput"
accept="image/*"
onchange="document.getElementById('uploadForm').submit()"
>
</form>

<!-- INLINE EDIT -->
<form id="inlineEditForm" method="POST" style="display:none;">
<input type="hidden" name="_method" value="PUT">
<input type="hidden" name="field" id="editField">
<input type="hidden" name="value" id="editValue">
</form>

<script>
/* AGE */
(function(){
const dob = "<%= dairy.dob ? dairy.dob.toISOString() : '' %>";
if(!dob) return;

const birth = new Date(dob);
const now = new Date();

let y = now.getFullYear() - birth.getFullYear();
let m = now.getMonth() - birth.getMonth();
let d = now.getDate() - birth.getDate();

if(d < 0){
m--;
d += 30;
}

if(m < 0){
y--;
m += 12;
}

document.getElementById("ageText").innerText =
y + " years, " + m + " months, " + d + " days";
})();

/* IMAGE LIST */
const images = [

<% if (dairy.profileImage) { %>
"/uploads/<%= dairy.profileImage %>",
<% } else { %>
"https://ui-avatars.com/api/?name=<%= encodeURIComponent(dairy.name) %>&background=198754&color=fff&size=600",
<% } %>

/uploads/sample-old-1.jpg",
"/uploads/sample-old-2.jpg"

];

let currentIndex = 0;

/* ACTION SHEET */
document.getElementById("profilePreview")
.addEventListener("click", function(){
document.getElementById("imageSheet").classList.add("show");
});

function closeSheet(){
document.getElementById("imageSheet").classList.remove("show");
}

/* GALLERY */
function openGallery(){
closeSheet();

document.getElementById("galleryImage").src =
images[currentIndex];

new bootstrap.Modal(
document.getElementById("viewImageModal")
).show();
}

function nextImage(){
currentIndex =
(currentIndex + 1) % images.length;

document.getElementById("galleryImage").src =
images[currentIndex];
}

function prevImage(){
currentIndex =
(currentIndex - 1 + images.length) % images.length;

document.getElementById("galleryImage").src =
images[currentIndex];
}

/* EDITABLE */
document.querySelectorAll(".editable")
.forEach(el => {

el.addEventListener("click", function(){

const field = this.dataset.field;
const current = this.dataset.value;

const value =
prompt("Update " + field, current);

if(value === null) return;

document.getElementById("editField").value = field;
document.getElementById("editValue").value = value;

const form =
document.getElementById("inlineEditForm");

form.action = "/dairy/<%= dairy._id %>";
form.submit();

});

});

/* MILKING */
document.getElementById("milkingToggle")
?.addEventListener("change", function(){

fetch("/dairy/<%= dairy._id %>/milking",{
method:"POST",
headers:{
"Content-Type":"application/json"
},
body:JSON.stringify({
isMilking:this.checked
})
});

const badge =
document.getElementById("milkBadge");

if(this.checked){
badge.innerText = "Being Milked";
badge.classList.remove("bg-secondary");
badge.classList.add("bg-success");
}else{
badge.innerText = "Not Milked";
badge.classList.remove("bg-success");
badge.classList.add("bg-secondary");
}

});
</script>
<!-- views/update.ejs -->

<div class="container mt-4">

  <div class="card shadow-sm border-0 p-4">
    <div class="row align-items-start g-4">

      <!-- LEFT : SMALL CIRCULAR PROFILE IMAGE -->
      <div class="col-md-4 text-center">

        <% if (dairy.profileImage) { %>
          <img
            src="/uploads/<%= dairy.profileImage %>"
            alt="<%= dairy.name %>"
            id="profilePreview"
            class="rounded-circle shadow profile-clickable"
            style="width:180px;height:180px;object-fit:cover;cursor:pointer;"
          >
        <% } else { %>
          <img
            src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(dairy.name) %>&background=198754&color=fff&size=300"
            alt="<%= dairy.name %>"
            id="profilePreview"
            class="rounded-circle shadow profile-clickable"
            style="width:180px;height:180px;object-fit:cover;cursor:pointer;"
          >
        <% } %>

        <% if (user && user.role === 'admin') { %>
          <small class="text-muted d-block mt-2">
            Tap image to view / change
          </small>
        <% } %>

      </div>

      <!-- RIGHT : DETAILS -->
      <div class="col-md-8">

        <h2 class="mb-3">
          <% if (user && user.role === 'admin') { %>
            <span class="editable" data-field="name" data-value="<%= dairy.name %>">
              <%= dairy.name %>
            </span>
          <% } else { %>
            <%= dairy.name %>
          <% } %>
        </h2>

        <h4 class="text-muted mb-3">
          Code:
          <% if (user && user.role === 'admin') { %>
            <span class="editable" data-field="code" data-value="<%= dairy.code %>">
              <%= dairy.code %>
            </span>
          <% } else { %>
            <%= dairy.code %>
          <% } %>
        </h4>

        <% if (dairy.code >= 0) { %>
          <p><strong>Gender:</strong> <%= dairy.gender %></p>
          <p><strong>Age:</strong> <span id="ageText"></span></p>
        <% } %>

        <p>
          <strong>Mass:</strong>

          <% if (user && user.role === 'admin') { %>
            <span class="editable" data-field="mass" data-value="<%= dairy.mass || 0 %>">
              <%= dairy.mass || 0 %>
            </span>
          <% } else { %>
            <%= dairy.mass || 0 %>
          <% } %>

          Kgs
        </p>

        <% if (dairy.gender === 'Female') { %>
          <p>
            <strong>Status:</strong>

            <% if (user && user.role === 'admin') { %>
              <label>
                <input
                  type="checkbox"
                  id="milkingToggle"
                  <%= dairy.isMilking ? 'checked' : '' %>
                >

                <span
                  id="milkBadge"
                  class="badge <%= dairy.isMilking ? 'bg-success' : 'bg-secondary' %>"
                >
                  <%= dairy.isMilking ? 'Being Milked' : 'Not Milked' %>
                </span>
              </label>
            <% } else { %>

              <span class="badge <%= dairy.isMilking ? 'bg-success' : 'bg-secondary' %>">
                <%= dairy.isMilking ? 'Being Milked' : 'Not Milked' %>
              </span>

            <% } %>

          </p>
        <% } %>

        <% if (user && user.role === 'admin') { %>
          <hr>

          <form
            action="/dairy/<%= dairy._id %>?_method=DELETE"
            method="POST"
            onsubmit="return confirm('Delete this profile permanently?')"
          >
            <button class="btn btn-danger">
              Delete Profile
            </button>
          </form>
        <% } %>

      </div>
    </div>
  </div>
</div>

<!-- VIEW IMAGE MODAL -->
<div class="modal fade" id="viewImageModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content border-0">

      <div class="modal-body p-0 position-relative bg-dark text-center">

        <% if (dairy.profileImage) { %>
          <img
            src="/uploads/<%= dairy.profileImage %>"
            class="img-fluid w-100"
            style="max-height:80vh;object-fit:contain;"
          >
        <% } else { %>
          <img
            src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(dairy.name) %>&background=198754&color=fff&size=600"
            class="img-fluid w-100"
            style="max-height:80vh;object-fit:contain;"
          >
        <% } %>

        <!-- FB STYLE COMMENT ICON -->
        <button
          class="btn btn-light rounded-circle position-absolute"
          style="bottom:15px;right:15px;width:55px;height:55px;"
          data-bs-toggle="modal"
          data-bs-target="#commentsModal"
        >
          💬
        </button>

        <% if (user && user.role === 'admin') { %>

          <button
            class="btn btn-light position-absolute"
            style="top:15px;right:15px;"
            data-bs-toggle="modal"
            data-bs-target="#changeImageModal"
          >
            Change
          </button>

        <% } %>

      </div>

    </div>
  </div>
</div>

<!-- COMMENTS MODAL -->
<div class="modal fade" id="commentsModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title">Image Comments</h5>
        <button class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body">

        <% if (updates && updates.length) { %>

          <% updates.forEach(item => { %>
            <div class="border rounded p-2 mb-2">
              <strong><%= item.user?.name || 'User' %></strong>
              <p class="mb-1"><%= item.comment %></p>
              <small class="text-muted">
                <%= item.createdAt.toDateString() %>
              </small>
            </div>
          <% }) %>

        <% } else { %>
          <p class="text-muted">No comments yet.</p>
        <% } %>

        <% if (user) { %>
          <form
            action="/dairy/<%= dairy._id %>/comment"
            method="POST"
            class="mt-3"
          >
            <textarea
              name="comment"
              class="form-control mb-2"
              rows="3"
              placeholder="Write comment..."
              required
            ></textarea>

            <button class="btn btn-primary">
              Post Comment
            </button>
          </form>
        <% } %>

      </div>

    </div>
  </div>
</div>

<!-- CHANGE IMAGE MODAL -->
<% if (user && user.role === 'admin') { %>
<div class="modal fade" id="changeImageModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title">Change Image</h5>
        <button class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body">

        <form
          action="/dairy/<%= dairy._id %>/image?_method=PUT"
          method="POST"
          enctype="multipart/form-data"
        >
          <input
            type="file"
            name="profileImage"
            class="form-control mb-3"
            required
          >

          <button class="btn btn-primary">
            Save Image
          </button>
        </form>

      </div>

    </div>
  </div>
</div>
<% } %>

<!-- INLINE FORM -->
<form id="inlineEditForm" method="POST" style="display:none;">
  <input type="hidden" name="_method" value="PUT">
  <input type="hidden" name="field" id="editField">
  <input type="hidden" name="value" id="editValue">
</form>

<!-- AGE -->
<script>
(function () {
  const dob = "<%= dairy.dob ? dairy.dob.toISOString() : '' %>";
  if (!dob) return;

  const birthDate = new Date(dob);
  const today = new Date();

  let years = today.getFullYear() - birthDate.getFullYear();
  let months = today.getMonth() - birthDate.getMonth();
  let days = today.getDate() - birthDate.getDate();

  if (days < 0) {
    months--;
    days += new Date(today.getFullYear(), today.getMonth(), 0).getDate();
  }

  if (months < 0) {
    years--;
    months += 12;
  }

  document.getElementById('ageText').innerText =
    years + ' years, ' + months + ' months, ' + days + ' days';
})();
</script>

<!-- EDIT -->
<% if (user && user.role === 'admin') { %>
<script>
document.querySelectorAll('.editable').forEach(el => {
  el.addEventListener('click', function () {

    const field = this.dataset.field;
    const current = this.dataset.value || this.innerText.trim();

    const value = prompt('Update ' + field, current);
    if (value === null) return;

    document.getElementById('editField').value = field;
    document.getElementById('editValue').value = value;

    const form = document.getElementById('inlineEditForm');
    form.action = '/dairy/<%= dairy._id %>';
    form.submit();
  });
});

document.getElementById('profilePreview')?.addEventListener('click', function () {
  const modal = new bootstrap.Modal(document.getElementById('viewImageModal'));
  modal.show();
});

document.getElementById('milkingToggle')?.addEventListener('change', function () {

  fetch('/dairy/<%= dairy._id %>/milking', {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({
      isMilking: this.checked
    })
  }).then(() => {

    const badge = document.getElementById('milkBadge');

    if (this.checked) {
      badge.innerText = 'Being Milked';
      badge.classList.remove('bg-secondary');
      badge.classList.add('bg-success');
    } else {
      badge.innerText = 'Not Milked';
      badge.classList.remove('bg-success');
      badge.classList.add('bg-secondary');
    }

  });

});
</script>
<% } else { %>
<script>
document.getElementById('profilePreview')?.addEventListener('click', function () {
  const modal = new bootstrap.Modal(document.getElementById('viewImageModal'));
  modal.show();
});
</script>
<% } %>
<style>
/* (reuse your same CSS or move to layout) */
.page { max-width: 1200px; margin: auto; }
.card { background:#fff; padding:22px; border-radius:14px; box-shadow:0 8px 20px rgba(0,0,0,.05); margin-bottom:20px; }
.section-title { font-size:18px; font-weight:600; margin-bottom:15px; padding-left:12px; border-left:5px solid #0b5d1e; color:#0b5d1e; }
.filters { display:flex; gap:10px; flex-wrap:wrap; margin-bottom:15px; }
input, select { padding:8px; border-radius:8px; border:1px solid #ddd; }
button { background:#0b5d1e; color:white; padding:9px 14px; border:none; border-radius:8px; cursor:pointer; }
table { width:100%; border-collapse:collapse; margin-top:10px; }
th, td { padding:10px; border-bottom:1px solid #eee; text-align:left; }
th { background:#f8f9fa; }
.total { margin-top:15px; padding:12px; background:#e9f7ef; border-left:5px solid #0b5d1e; font-weight:bold; }
</style>

<div class="page">

  <div class="card">
    <div class="section-title">Daily Customer Sales</div>

    <form class="filters" method="GET" action="/financials/daily-customers">
      <input type="date" name="day" value="<%= day || '' %>">
      <button>Filter</button>
    </form>

    <% if (sales && sales.length > 0) { %>
      <table>
        <thead>
          <tr>
            <th>Customer</th>
            <th>Liters</th>
            <th>Cash</th>
          </tr>
        </thead>
        <tbody>
          <% sales.forEach(s => { %>
            <tr>
              <td><%= s.customerName %></td>
              <td><%= s.liters %></td>
              <td>KES <%= s.cash %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>

      <div class="total">
        Total Sales Cash: KES <%= totalSalesCash || 0 %>
      </div>

    <% } else { %>
      <p>No sales records found.</p>
    <% } %>

  </div>
</div>